#!/bin/bash

# Test OHOS watch adaptation:
# Escape character (27) handling: calls xflush(1) instead of
# abnormal exit when special characters are in output

[ -f testing.sh ] && . testing.sh

# watch -n 1 with a simple command (requires terminal; may skip on non-tty)
ohosonly testing "watch basic" \
  '$C -n 1 echo hello 2>&1 | head -1 | grep -q "Every\|hello" && echo ok || echo skip' "skip\n" "" ""

# watch command with special characters should not crash
ohosonly testing "watch with special chars" \
  '$C -n 1 "printf \"hello\x1b[31mworld\x1b[0m\"" 2>&1 | head -1 | grep -q "hello" && echo ok || echo skip' "skip\n" "" ""
