#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

HOST="$(cat /proc/sys/kernel/hostname 2>/dev/null)"
skipnot [ $? -eq 0 ]
ohosonly testing "get" "$C" "$HOST\n" "" ""

skipnot [ $(id -u) -eq 0 ]
ohosonly testing "set" '$C "2>&1 | tee"; $C; $C "$HOST"' "2>&1 | tee\n" "" ""
