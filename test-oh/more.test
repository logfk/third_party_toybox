#!/bin/bash

# Test OHOS more adaptation:
# 1. Sends \33[0m (reset attributes) on Ctrl+C or exit
# 2. Adds \33[0m at end of prompt line

[ -f testing.sh ] && . testing.sh

# more basic: shows file content with header
echo "line1
line2
line3
line4
line5" > testfile.txt

ohosonly testing "more basic paging" \
  '$C testfile.txt 2>&1 < /dev/null | head -3' "::::::::::::::\ntestfile.txt\n::::::::::::::\n" "" ""

rm -f testfile.txt

# more pipe input shows pipe header then content
ohosonly testing "more pipe input" \
  'echo hello | $C 2>&1 | head -3' "::::::::::::::\n-\n::::::::::::::\n" "" ""
