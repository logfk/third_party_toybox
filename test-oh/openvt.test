#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# openvt requires root and a real VT console; tests skip without
ohosonly testcmd "help" \
  "--help >/dev/null 2>&1 && echo ok" "ok\n" "" ""

# no args should error
ohosonly testing "no args" "$C >/dev/null 2>&1 && echo BAD || echo ok" "ok\n" "" ""

# -c NUM flag (specify VT number) — succeeds on this board
ohosonly testing "-c flag" \
  "$C -c 1 /bin/true >/dev/null 2>&1 && echo ok || echo skip" "ok\n" "" ""

# -s switch to new VT — requires real console
ohosonly testing "-s flag" \
  "$C -s /bin/true >/dev/null 2>&1 && echo ok || echo skip" "skip\n" "" ""

# -w wait for command — requires real console
ohosonly testing "-w flag" \
  "$C -w /bin/true >/dev/null 2>&1 && echo ok || echo skip" "skip\n" "" ""
