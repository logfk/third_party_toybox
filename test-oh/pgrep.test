# Copyright 2013 Robin Mittal <robinmittal.it@gmail.com>

#cleaning 'yes' processes
killall yes >/dev/null 2>&1

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# Starting processes to test pgrep command
yes >/dev/null &
proc=$!
#echo "# Process created with id: $proc"
sleep .1
session_id=0
proc_parent=`cat /proc/${proc}/stat | cut -d' ' -f4`
#echo "# Parent Process id of $proc is $proc_parent"

# Testcases for pgrep command
ohosonly testing "pattern" "$C yes" "$proc\n" "" ""
ohosonly testing "wildCardPattern" "$C ^y.*s$" "$proc\n" "" ""
ohosonly testing "-l pattern" "$C -l yes" "$proc yes\n" "" ""
ohosonly testing "-f pattern" "$C -f yes" "$proc\n" "" ""
ohosonly testing "-n pattern" "$C -n yes" "$proc\n" "" ""
ohosonly testing "-o pattern" "$C -o yes" "$proc\n" "" ""
ohosonly testing "-s" "$C -s $session_id yes" "$proc\n" "" ""
ohosonly testing "-P" "$C -P $proc_parent yes" "$proc\n" "" ""

ohosonly testing "return success" "$C yes && echo success" "$proc\nsuccess\n" "" ""
ohosonly testing "return failure" "$C almost-certainly-not || echo failure"      "failure\n" "" ""

#Clean-up
kill -9 $proc
