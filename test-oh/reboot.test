#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# reboot/halt/poweroff are dangerous; only test help and flag parsing
ohosonly testcmd "help" \
  "--help >/dev/null 2>&1 && echo ok" "ok\n" "" ""

# -n flag (don't sync) — must not actually reboot
ohosonly testcmd "-n flag help" \
  "$C -n --help >/dev/null 2>&1 && echo ok" "ok\n" "" ""

# -d delay flag
ohosonly testcmd "-d flag help" \
  "$C -d 0 --help >/dev/null 2>&1 && echo ok" "ok\n" "" ""

# -f force flag
ohosonly testcmd "-f flag help" \
  "$C -f --help >/dev/null 2>&1 && echo ok" "ok\n" "" ""
