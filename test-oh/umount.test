#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# umount: test via error cases (no real unmounting needed)

ohosonly testing "no args fails" \
  '$C 2>&1 | grep -q "Need" && echo yes' "yes\n" "" ""
ohosonly testing "--help recognized" \
  '$C --help >/dev/null 2>&1 && echo ok' "ok\n" "" ""
ohosonly testing "nonexistent path fails" \
  '$C /nonexistent >/dev/null 2>&1 && echo BAD || echo yes' "yes\n" "" ""
ohosonly testing "-v nonexistent" \
  '$C -v /nonexistent >/dev/null 2>&1 && echo BAD || echo yes' "yes\n" "" ""
ohosonly testing "-f nonexistent" \
  '$C -f /nonexistent >/dev/null 2>&1 && echo BAD || echo yes' "yes\n" "" ""
