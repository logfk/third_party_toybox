#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# makedevs creates device nodes from a device table
ohosonly testcmd "help" \
  "--help >/dev/null 2>&1 && echo ok" "ok\n" "" ""

# no args should error (needs rootdir)
ohosonly testing "no args" "$C 2>/dev/null; echo \$?" "1\n" "" ""

# create temp dir and a simple device table
mkdir -p _makedevs_devdir
echo "null c 0666 0 0 1 3 0 0" > _makedevs_table.txt
ohosonly testing "-d table" \
  "$C -d _makedevs_table.txt _makedevs_devdir >/dev/null 2>&1 && echo ok" "ok\n" "" ""
rm -rf _makedevs_devdir _makedevs_table.txt

# nonexistent rootdir should error
ohosonly testing "bad rootdir" \
  "$C _nonexistent_rootdir_xyz >/dev/null 2>&1 && echo BAD || echo ok" "ok\n" "" ""
