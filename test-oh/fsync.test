#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# fsync flushes file data to disk
ohosonly testcmd "help" \
  "--help >/dev/null 2>&1 && echo ok" "ok\n" "" ""

# no args should error
ohosonly testing "no args" "$C 2>&1; echo \$?" "fsync: Needs 1 argument (see \"fsync --help\")\n1\n" "" ""

# sync a real file (use current dir, /tmp may be read-only on OHOS)
echo "test data" > _fsync_test_00001
ohosonly testcmd "sync file" \
  "_fsync_test_00001 && echo ok" "ok\n" "" ""
rm -f _fsync_test_00001

# -d flag (fdatasync only)
echo "test data" > _fsync_test_00002
ohosonly testcmd "-d sync file" \
  "-d _fsync_test_00002 && echo ok" "ok\n" "" ""
rm -f _fsync_test_00002

# nonexistent file should error
ohosonly testcmd "bad file" \
  "_nonexistent_fsync 2>&1; echo \$?" "fsync: _nonexistent_fsync: No such file or directory\n1\n" "" ""
