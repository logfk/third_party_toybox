#!/bin/bash

# Test OHOS mkswap adaptation:
# NULL/error check on xopen(): return early if fd < 0

[ -f testing.sh ] && . testing.sh

# mkswap on non-existent file should exit with error
ohosonly testcmd "mkswap missing file" \
  "/nonexistent/swapfile 2>/dev/null; echo $?" "1\n" "" ""

# Create swap file and mkswap it
dd if=/dev/zero of=swapfile bs=1024 count=8 2>/dev/null

ohosonly testcmd "mkswap valid file" \
  "swapfile 2>&1 | grep -ci swap || echo no" "1\n" "" ""

rm -f swapfile

# mkswap on zero-length file succeeds (toybox handles it)
touch emptyfile

ohosonly testcmd "mkswap empty file succeeds" \
  "emptyfile >/dev/null 2>&1 && echo ok" "ok\n" "" ""

rm -f emptyfile
