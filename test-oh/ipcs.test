#!/bin/bash

# Test OHOS ipcs adaptations:
# 1. Remove -s (semaphore) flag from opts
# 2. Disable sem_array() function
# 3. Default flags only include FLAG_m|FLAG_q

[ -f testing.sh ] && . testing.sh

# ipcs basic output
ohosonly testing "ipcs basic" \
  '$C 2>/dev/null | head -5 | grep -q "IPC\|Message\|Shared" && echo ok || echo skip' "skip\n" "" ""

# ipcs -q (message queues)
ohosonly testing "ipcs -q" \
  '$C -q 2>/dev/null | head -3 | grep -q "Message\|T" && echo ok || echo skip' "skip\n" "" ""

# ipcs -m (shared memory)
ohosonly testing "ipcs -m" \
  '$C -m 2>/dev/null | head -3 | grep -q "Shared\|T" && echo ok || echo skip' "skip\n" "" ""

# ipcs -s (semaphores) - under OHOS should either error or show no data
ohosonly testing "ipcs -s no semaphores" \
  '$C -s 2>/dev/null | head -5 | grep -c "semaphore\|Semaphore" || echo nosem' "nosem\n" "" ""
