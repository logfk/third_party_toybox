#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

ohosonly testcmd "help" "--help >/dev/null 2>&1 && echo ok" "ok\n" "" ""

# no args should fail (needs at least 2 args)
ohosonly testcmd "no args" "$C 2>/dev/null; echo \$?" "1\n" "" ""

# create a named pipe
ohosonly testcmd "fifo" "$C /tmp/_test_fifo p && ls -la /tmp/_test_fifo && rm -f /tmp/_test_fifo" "" "" ""
