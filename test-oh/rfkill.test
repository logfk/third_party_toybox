#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

ohosonly testcmd "help" "--help >/dev/null 2>&1 && echo ok" "ok\n" "" ""

# no args should fail (needs command)
ohosonly testcmd "no args" "$C 2>/dev/null; echo \$?" "1\n" "" ""

# bad command should fail
ohosonly testcmd "bad cmd" "$C badcmd 2>/dev/null; echo \$?" "1\n" "" ""
