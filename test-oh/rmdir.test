#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

mkdir one
ohosonly testing "rmdir" "$C one && [ ! -d one ] && echo yes" "yes\n" "" ""

touch walrus
ohosonly testing "file"  	"$C walrus 2> /dev/null || [ -f walrus ] && echo yes" "yes\n" "" ""

mkdir one two
ohosonly testing "one two"  	"$C one two 2> /dev/null && [ ! -d one ] && [ ! -d two ] && echo yes"  	"yes\n" "" ""

mkdir one two three
ohosonly testing "one missing two file three"  	"$C one missing two walrus three 2> /dev/null || [ ! -d three ] && echo yes"  	"yes\n" "" ""
rm walrus

mkdir one
chmod 000 one
ohosonly testing "mode 000" "$C one && [ ! -d one ] && echo yes" "yes\n" "" ""

mkdir temp
touch temp/thing
ohosonly testing "non-empty"  	"$C temp 2>/dev/null || [ -d temp ] && echo yes" "yes\n" "" ""
ohosonly testing "-p dir/file"  	"$C -p temp/thing 2>/dev/null || [ -f temp/thing ] && echo yes"  	"yes\n" "" ""

mkdir -p temp/one/two/three
ohosonly testing "-p part of path"  	"$C -p temp/one/two/three 2>/dev/null || [ -d temp ] && [ ! -e temp/one ] && echo yes"  	"yes\n" "" ""
rm -rf temp

skipnot [ $UID -eq 0 ]
ohosonly testing '-p abspath'    'mkdir -p /test/2/3 && $C -p /test/2/3 && [ ! -e /test ] && echo yes'    'yes\n' '' ''

mkdir -p one/two/three
ohosonly testing "-p one/two/three"  	"$C -p one/two/three && [ ! -e one ] && echo yes" "yes\n" "" ""

mkdir -p one/two/three
ohosonly testing "-p one/two/three/"  	"$C -p one/two/three/ && [ ! -e one ] && echo yes" "yes\n" "" ""

#mkdir -p one/two/three
#chmod 000 one/two/three one/two one
#testing "-p one/two/three"  #	"rmdir -p one/two/three && [ ! -e one ] && echo yes" "yes\n" "" ""
