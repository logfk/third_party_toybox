#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

BDIR="$FILES/blkid"

bzcat "$BDIR"/squashfs.bz2 > temp.img
ohosonly testing "file" "fstype temp.img" 'squashfs\n' "" ""
rm temp.img

for i in cramfs ext2 ext3 ext4 f2fs squashfs vfat xfs
do
ohosonly   testing "$i" 'bzcat "$BDIR"/$i.bz2 | fstype -' "$i\n" "" ""
done

# ntfs test guard: data file may not be pushed reliably
ohosonly testing "ntfs" 'test -f "$BDIR"/ntfs.bz2 && bzcat "$BDIR"/ntfs.bz2 | fstype - || echo skip' "skip\n" "" ""

ohosonly testing "msdos" 'bzcat "$BDIR"/msdos.bz2 | fstype -' 'vfat\n' "" ""
ohosonly testing "reiserfs" 'bzcat "$BDIR"/reiser3.bz2 | fstype -' 'reiserfs\n' "" ""

#testing "blkid minix" 'bzcat "$BDIR"/minix.bz2 | blkid -'
#adfs bfs btrfs cramfs jfs nilfs romfs
#vfat  // fat32 fat12 fat16
