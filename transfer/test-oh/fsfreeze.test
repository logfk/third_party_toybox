#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# fsfreeze requires a mountpoint and root; tests skip without
ohosonly testcmd "help" \
  "--help 2>&1 | grep -qi 'fsfreeze' && echo ok" "ok\n" "" ""

# no args should error
ohosonly testing "no args" "$C 2>&1; echo \$?" "fsfreeze: Needs 1 argument (see \"fsfreeze --help\")\n1\n" "" ""

# -f freeze on /tmp (may succeed or fail depending on mount)
ohosonly testcmd "-f non-mount" \
  "-f /tmp 2>&1 && echo ok || echo skip" "ok\n" "" ""

# -u unfreeze on /tmp (may succeed or fail depending on mount)
ohosonly testcmd "-u non-mount" \
  "-u /tmp 2>&1 && echo ok || echo skip" "ok\n" "" ""
