#!/bin/bash

# Test OHOS netstat adaptations:
# 1. inode format width (%-13s -> %13s, %-8lu -> %8lu)
# 2. UNIX domain socket header format (adds RefCnt Flags columns)

[ -f testing.sh ] && . testing.sh

# netstat -x (unix domain sockets) - header is on line 2
ohosonly testing "netstat -x has RefCnt" \
  '$C -x 2>/dev/null | head -2 | tail -1 | grep -q "RefCnt" && echo ok' "ok\n" "" ""

# netstat -t (tcp sockets)
ohosonly testing "netstat -t" \
  '$C -t 2>/dev/null | head -3 | grep -q "tcp" && echo ok' "ok\n" "" ""

# netstat -u (udp sockets - may be empty in containers)
ohosonly testing "netstat -u" \
  '$C -u 2>/dev/null | head -3 | grep -q "udp" && echo ok || echo skip' "ok\n" "" ""

# netstat -l (listening sockets)
ohosonly testing "netstat -l" \
  '$C -l 2>/dev/null | head -3 | grep -q "LISTEN\|Active" && echo ok' "ok\n" "" ""

# netstat -n (numeric) - header is on line 2
ohosonly testing "netstat -n" \
  '$C -n 2>/dev/null | head -2 | tail -1 | grep -q "Proto" && echo ok' "ok\n" "" ""

# netstat -r (routing table)
ohosonly testing "netstat -r" \
  '$C -r 2>/dev/null | head -5 | grep -q "Destination\|Kernel\|Iface" && echo ok || echo skip' "ok\n" "" ""
