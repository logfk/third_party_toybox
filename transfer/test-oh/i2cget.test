#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# --help always works, no hardware needed
ohosonly testcmd "help" "--help 2>&1 >/dev/null && echo ok" "ok\n" "" ""

# no args should error: needs BUS and CHIP
ohosonly testcmd "no args" "2>/dev/null && echo ok || echo fail" "fail\n" "" ""

# only BUS given (missing CHIP) should error
ohosonly testcmd "missing chip" "0 2>/dev/null && echo ok || echo fail" "fail\n" "" ""

# get from bus 0 chip 0x50 register 0x00 (needs I2C hardware)
ohosonly testing "get bus 0 chip 0x50" "$C -y 0 0x50 0x00 2>/dev/null && echo ok || echo skip" "skip\n" "" ""
