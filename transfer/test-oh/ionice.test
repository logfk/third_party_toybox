#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# --help always works, no hardware needed
ohosonly testcmd "help" "--help 2>&1 | grep -c 'ionice'" "1\n" "" ""

# no args and no -p should error: need -p or COMMAND
ohosonly testcmd "no args" "2>/dev/null; echo \$?" "1\n" "" ""

# -p $$ queries current process IO priority (works without special hardware)
ohosonly testing "query self" "$C -p $$ 2>/dev/null | grep -qi 'best-effort\|realtime\|idle\|unknown' && echo ok || echo skip" "ok\n" "" ""

# -c 2 -n 5 echo test sets IO class and runs command (works without I2C hardware)
ohosonly testing "set class run cmd" "$C -c 2 -n 5 echo ok 2>/dev/null" "ok\n" "" ""
