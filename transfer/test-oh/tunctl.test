#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# tunctl requires /dev/net/tun; tests skip without
ohosonly testcmd "help" \
  "--help 2>&1 | grep -qi 'tunctl' && echo ok" "ok\n" "" ""

# no args should error (needs NAME)
ohosonly testing "no args" "$C 2>/dev/null; echo \$?" "1\n" "" ""

# -d delete flag (will fail without /dev/net/tun)
ohosonly testing "-d flag" \
  "$C -d test_tun0 2>/dev/null; echo \$?" "" "" ""

# -t create flag (will fail without /dev/net/tun)
ohosonly testing "-t flag" \
  "$C -t test_tun0 2>/dev/null; echo \$?" "" "" ""

# -T tap mode flag (will fail without /dev/net/tun)
ohosonly testing "-T flag" \
  "$C -T test_tap0 2>/dev/null; echo \$?" "" "" ""
