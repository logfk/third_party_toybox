#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

ohosonly testcmd "help" "--help 2>&1 | grep -qi 'sleep' && echo ok" "ok\n" "" ""

# no args should fail
ohosonly testcmd "no args" "$C 2>/dev/null; echo \$?" "1\n" "" ""

# sleep for 0 seconds
ohosonly testing "zero" "$C 0 && echo ok" "ok\n" "" ""
