#!/bin/bash

#testing "name" "command" "result" "infile" "stdin"

echo "xxxxxxxxhello, world!" > foo
ohosonly testcmd 'read default (4)' '-f foo 0x8' '0x6c6c6568\n' '' ''
ohosonly testcmd 'read 1' '-f foo 0x8 1' '0x68\n' '' ''
ohosonly testcmd 'read 2' '-f foo 0x8 2' '0x6568\n' '' ''
ohosonly testcmd 'read 4' '-f foo 0x8 4' '0x6c6c6568\n' '' ''
ohosonly testcmd 'read 8' '-f foo 0x8 8' '0x77202c6f6c6c6568\n' '' ''

ohosonly testcmd 'read --no-mmap default (4)' '--no-mmap -f foo 0x8' '0x6c6c6568\n' '' ''
ohosonly testcmd 'read --no-mmap 1' '--no-mmap -f foo 0x8 1' '0x68\n' '' ''
ohosonly testcmd 'read --no-mmap 2' '--no-mmap -f foo 0x8 2' '0x6568\n' '' ''
ohosonly testcmd 'read --no-mmap 4' '--no-mmap -f foo 0x8 4' '0x6c6c6568\n' '' ''
ohosonly testcmd 'read --no-mmap 8' '--no-mmap -f foo 0x8 8' '0x77202c6f6c6c6568\n' '' ''

# 以下 write 用例使用 devmem 回读验证，避免对 od 输出格式的依赖
# （toybox od 列间用 tab，GNU od 用空格，格式不兼容）
head -c 32 /dev/zero > foo
ohosonly testcmd 'write 1' '-f foo 0x8 1 0x12 && '"$C"' -f foo 0x8 1' '0x12\n' '' ''
ohosonly testcmd 'write 2' '-f foo 0x8 2 0x1234 && '"$C"' -f foo 0x8 2' '0x1234\n' '' ''
ohosonly testcmd 'write 4' '-f foo 0x8 4 0x12345678 && '"$C"' -f foo 0x8 4' '0x12345678\n' '' ''
ohosonly testcmd 'write 8' '-f foo 0x8 8 0x12345678abcdef01 && '"$C"' -f foo 0x8 8' '0x12345678abcdef01\n' '' ''

head -c 32 /dev/zero > foo
ohosonly testcmd 'write --no-mmap 1' '--no-mmap -f foo 0x8 1 0x12 && '"$C"' -f foo 0x8 1' '0x12\n' '' ''
ohosonly testcmd 'write --no-mmap 2' '--no-mmap -f foo 0x8 2 0x1234 && '"$C"' -f foo 0x8 2' '0x1234\n' '' ''
ohosonly testcmd 'write --no-mmap 4' '--no-mmap -f foo 0x8 4 0x12345678 && '"$C"' -f foo 0x8 4' '0x12345678\n' '' ''
ohosonly testcmd 'write --no-mmap 8' '--no-mmap -f foo 0x8 8 0x12345678abcdef01 && '"$C"' -f foo 0x8 8' '0x12345678abcdef01\n' '' ''
