#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# logger sends to syslog; test basic functionality
ohosonly testcmd "help" \
  "--help 2>&1 | grep -qi 'logger' && echo ok" "ok\n" "" ""

# basic message logging (should succeed)
ohosonly testcmd "log message" \
  "$C 'test message from toybox' && echo ok" "ok\n" "" ""

# -t TAG flag
ohosonly testcmd "-t tag" \
  "$C -t test_tag 'tagged message' && echo ok" "ok\n" "" ""

# -p priority flag
ohosonly testcmd "-p priority" \
  "$C -p local0.notice 'priority message' && echo ok" "ok\n" "" ""

# -s flag (write to stderr too)
ohosonly testcmd "-s stderr" \
  "$C -s -t test_src 'stderr test' 2>&1 | grep -qi 'stderr test' && echo ok" "ok\n" "" ""
