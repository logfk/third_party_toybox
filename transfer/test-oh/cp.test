#!/bin/bash

[ -f testing.sh ] && . testing.sh

OLDUMASK=$(umask)
umask 0002

# Create test file
dd if=/dev/urandom of=random bs=64 count=1 2> /dev/null

#testing "name" "command" "result" "infile" "stdin"

ohosonly testing "not enough arguments [fail]" "$C one 2>/dev/null || echo yes"  	"yes\n" "" ""
ohosonly testing "-missing source [fail]" "$C missing two 2>/dev/null || echo yes"  	"yes\n" "" ""
ohosonly testing "file->file" "$C random two && cmp random two && echo yes"  	"yes\n" "" ""
rm two

mkdir two
ohosonly testing "file->dir" "$C random two && cmp random two/random && echo yes"  	"yes\n" "" ""
rm two/random
ohosonly testing "file->dir/file"  	"$C random two/random && cmp random two/random && echo yes"  	"yes\n" "" ""
ohosonly testing "-r dir->missing"  	"$C -r two three && cmp random three/random && echo yes"  	"yes\n" "" ""
touch walrus
ohosonly testing "-r dir->file [fail]"  	"$C -r two walrus 2>/dev/null || echo yes" "yes\n" "" ""
touch two/three
ohosonly testing "-r dir hits file."  	"$C -r three two 2>/dev/null || echo yes" "yes\n" "" ""
rm -rf two three walrus

touch two
chmod 000 two
skipnot [ $(id -u) -ne 0 ]  # Root doesn't count.
ohosonly testing "file->inaccessible [fail]"  	"$C random two 2>/dev/null || echo yes" "yes\n" "" ""
rm -f two

touch two
chmod 000 two
skipnot [ $(id -u) -ne 0 ]  # Root doesn't count.
ohosonly testing "-f file->inaccessible"  	"$C -f random two && cmp random two && echo yes" "yes\n" "" ""
mkdir sub
chmod 000 sub
skipnot [ $(id -u) -ne 0 ]  # Root doesn't count.
ohosonly testing "file->inaccessible_dir [fail]"  	"$C random sub 2>/dev/null || echo yes" "yes\n" "" ""
rm two
rmdir sub

# This test fails because our -rf deletes existing target files without
# regard to what we'd be copying over it. Posix says to only do that if
# we'd be copying a file over the file, but does not say _why_.

#mkdir dir
#touch file
#testing "-rf dir file [fail]" "$C -rf dir file 2>/dev/null || echo yes"  #	"yes\n" "" ""
#rm -rf dir file

touch one two
ohosonly testing "file1 file2 missing [fail]"  	"$C one two missing 2>/dev/null || echo yes" "yes\n" "" ""
mkdir dir
ohosonly testing "dir file missing [fail]"  	"$C dir two missing 2>/dev/null || echo yes" "yes\n" "" ""
ohosonly testing "-rf dir file missing [fail]"  	"$C dir two missing 2>/dev/null || echo yes" "yes\n" "" ""
ohosonly testing "file1 file2 file [fail]"  	"$C random one two 2>/dev/null || echo yes" "yes\n" "" ""
ohosonly testing "file1 file2 dir"  	"$C random one dir && cmp random dir/random && cmp one dir/one && echo yes"  	"yes\n" "" ""
rm one two random
rm -rf dir

mkdir -p one/two/three/four
touch one/two/three/five one/{six,seven,eight}
ohosonly testing "-r /abspath dest"  	"$C -r \"$(readlink -f one)\" dir && cmp one/six dir/six && cmp one/two/three/five dir/two/three/five && echo yes"  	"yes\n" "" ""
ohosonly testing "-r dir again" "$C -r one/. dir && cmp one/six dir/six && cmp one/two/three/five dir/two/three/five && echo yes"  	"yes\n" "" ""
mkdir dir2
ohosonly testing "-r dir1/* dir2"  	"$C -r one/* dir2 && cmp one/six dir2/six && cmp one/two/three/five dir2/two/three/five && echo yes" "yes\n" "" ""
rm -rf one dir dir2

mkdir one; touch one/two; cp one/two one/three
cp -pr one/ one_ # Succeeds twice in a row
ohosonly testing "-pr dir/." "$C -pr one/. one_ && echo yes" "yes\n" "" ""
rm -rf one one_
mkdir one; touch one/two; ln -s two one/three
cp -pr one/ one_ # First time ok, second mustn't fail with "File exists"
ohosonly testing "-pr dir/. symlink child" "$C -pr one/. one_ && echo yes" "yes\n" "" ""
rm -rf one one_

touch walrus
chmod 644 walrus
ln -s walrus woot
ohosonly testing "symlink dest permissions" "$C woot carpenter && stat -c %A carpenter"    "-rw-r--r--\n" "" ""
ohosonly testing "duplicated --preserve options"    "$C --preserve=mode,mode walrus walrus2 2>&1 || echo bad" "" "" ""
rm -rf walrus woot carpenter

mkdir dir
echo a > file
echo b > b
ohosonly testing "-T file" "$C -T b file && cat file" "b\n" "" ""
ohosonly testing "-T dir" "$C -T b dir 2>/dev/null || echo expected" "expected\n" "" ""
rm b file

mkdir -p b/c/d/ a/
echo a > b/c/d/file
ohosonly testing "--parents b/c/d/file a/" "$C --parents b/c/d/file a/ && cat a/b/c/d/file" "a\n" "" ""
rm -rf a/ b/

echo a > file
ohosonly testing "-P file" "$C -P file fdst && stat -c %F fdst" "regular file\n" "" ""
ln -s file lnk
ohosonly testing "-P symlink" "$C -P lnk ldst && stat -c %F ldst" "symbolic link\n" "" ""
ohosonly testing "follow symlink" "$C lnk ldst2 && stat -c %F ldst2" "regular file\n" "" ""
rm file fdst lnk ldst ldst2

mkdir sub
ohosonly testing "-t one arg" '$C -t sub/ input && cat sub/input' 'yes\n' 'yes\n' ''
ohosonly
toyonly testing "-Dt" '$C -Dt sub2 input && cat sub2/input' 'and\n' 'and\n' ''
rm -rf sub sub2

ohosonly testing '-u1' 'echo one>one; sleep .1; echo two>two; $C -u one two; cat two'    'two\n' '' ''
ohosonly testing '-u2' 'echo two>two; sleep .1; echo one>one; $C -u one two; cat two'    'one\n' '' ''
mkdir a b

echo potato > a/one
echo potato > a/two
touch b/one b/two
ohosonly testing '-i' '$C -ri a/. b/. 2>/dev/null; cmp -s a/one b/one || cmp -s a/one b/two && echo yes'    'yes\n' '' 'n\ny\n'
rm -rf one two a b

# cp -r ../source destdir
# cp -r one/two/three missing
# cp -r one/two/three two
# cp file1 file2 dir
# cp file1 missing file2 -> dir

# Make sure it's truncating existing file
# copy with -d at top level, with -d in directory, without -d at top level,
#      without -d in directory

umask $OLDUMASK

# === Flag tests for untested flags ===

# -v: verbose output
echo hello > _cp_testfile
ohosonly testing "cp -v verbose output" \
  '$C -v _cp_testfile _cp_testdst && echo done' \
  "'_cp_testfile' -> '_cp_testdst'\ndone\n" "" ""
rm -f _cp_testfile _cp_testdst

# -R: recursive copy directory
mkdir -p _cp_testdir/sub
echo data > _cp_testdir/file
echo deep > _cp_testdir/sub/deepfile
ohosonly testing "cp -R recursive dir copy" \
  '$C -R _cp_testdir _cp_testdst && cat _cp_testdst/file && cat _cp_testdst/sub/deepfile' \
  "data\ndeep\n" "" ""
rm -rf _cp_testdir _cp_testdst

# -a: archive mode (preserve all + recursive)
mkdir -p _cp_testdir
echo data > _cp_testdir/afile
ohosonly testing "cp -a archive copy" \
  '$C -a _cp_testdir _cp_testdst && cat _cp_testdst/afile' \
  "data\n" "" ""
rm -rf _cp_testdir _cp_testdst

# -L: follow symlinks (copy target, not link)
echo real > _cp_realfile
ln -sf _cp_realfile _cp_link
ohosonly testing "cp -L follows symlink" \
  '$C -L _cp_link _cp_testdst && stat -c %F _cp_testdst' \
  "regular file\n" "" ""
rm -f _cp_realfile _cp_link _cp_testdst

# -i: interactive (prompts before overwrite) - test with stdin
echo old > _cp_overwrite
echo new > _cp_newfile
ohosonly testing "cp -i prompts on overwrite" \
  '$C -i _cp_newfile _cp_overwrite && cat _cp_overwrite' \
  "new\n" "" "y\n"
rm -f _cp_overwrite _cp_newfile

# -n: no-clobber (don't overwrite)
echo original > _cp_noclobber
echo fresh > _cp_fresh
ohosonly testing "cp -n no clobber" \
  '$C -n _cp_fresh _cp_noclobber && cat _cp_noclobber' \
  "original\n" "" ""
rm -f _cp_noclobber _cp_fresh
