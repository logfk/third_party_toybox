#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

ohosonly testing "not enough args [fail]" "$C 2>/dev/null" "" "" ""

ohosonly testing "uu empty file" "$C test"  	"begin 744 test\nend\n" "" "" 
ohosonly testing "uu 1-char" "$C test"  	"begin 744 test\n!80\`\`\nend\n" "" "a" 
ohosonly testing "uu 2-char" "$C test"  	"begin 744 test\n\"86(\`\nend\n" "" "ab" 
ohosonly testing "uu 3-char" "$C test"  	"begin 744 test\n#86)C\nend\n" "" "abc" 

ohosonly testing "b64 empty file" "$C -m test"  	"begin-base64 744 test\n====\n" "" "" 
ohosonly testing "b64 1-char" "$C -m test"  	"begin-base64 744 test\nYQ==\n====\n" "" "a" 
ohosonly testing "b64 2-char" "$C -m test"  	"begin-base64 744 test\nYWI=\n====\n" "" "ab" 
ohosonly testing "b64 3-char" "$C -m test"  	"begin-base64 744 test\nYWJj\n====\n" "" "abc" 

