#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

ohosonly testcmd "help" "--help 2>&1 | grep -qi 'usleep' && echo ok" "ok\n" "" ""

# no args should fail
ohosonly testing "no args" "$C >/dev/null 2>&1 && echo BAD || echo ok" "ok\n" "" ""

# sleep 1 microsecond
ohosonly testing "1us" "$C 1 && echo ok" "ok\n" "" ""
