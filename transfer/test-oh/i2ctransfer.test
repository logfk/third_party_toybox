#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# i2ctransfer requires i2c bus; tests skip without hardware
ohosonly testcmd "help" \
  "--help 2>&1 | grep -qi 'i2ctransfer' && echo ok" "ok\n" "" ""

# no args should error
ohosonly testing "no args" "$C 2>&1; echo \$?" "1\n" "" ""

# missing desc argument (only bus)
ohosonly testing "missing desc" "$C 1 2>&1; echo \$?" "1\n" "" ""

# -v -f -y with bad bus (should error)
ohosonly testcmd "-v -f -y bad bus" \
  "$C -v -f -y 999 w1@0x50 0x00 2>&1; echo \$?" "" "" ""
