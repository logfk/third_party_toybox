#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

ohosonly testing "minix bzcat" \
  "$TOYBOX bzcat $FILES/blkid/minix.bz2 | $TOYBOX sha1sum | $TOYBOX cut -d ' ' -f 1" \
  '9eb6cc72494f0e227420d3272c5ad92f8db57291\n' '' ''

ohosonly testing "ntfs bzcat" \
  'test -f "$FILES"/blkid/ntfs.bz2 && $TOYBOX bzcat "$FILES"/blkid/ntfs.bz2 | $TOYBOX sha1sum | $TOYBOX cut -d " " -f 1 || echo skip' \
  "skip\n" '' ''

ohosonly testing "overflow" \
  "$TOYBOX bzcat $FILES/bzcat/overflow.bz2 >/dev/null 2>/dev/null ; [ \$? -ne 0 ] && echo good" \
  "good\n" "" ""

ohosonly testing "badcrc" \
  "$TOYBOX bzcat $FILES/bzcat/badcrc.bz2 > /dev/null 2>/dev/null ; [ \$? -ne 0 ] && echo good" \
  "good\n" "" ""
