#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# ascii has no flags, just prints the ASCII table
ohosonly testcmd "help" "--help 2>&1 | grep -qi 'ascii' && echo ok" "ok\n" "" ""

# no args prints full table
ohosonly testcmd "no args" "$C 2>&1 | grep -c 'NUL'" "1\n" "" ""

# output contains Dec Hex header
ohosonly testcmd "header" "$C 2>&1 | grep -c 'Dec Hex'" "1\n" "" ""
