#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

SIZE='&& stat -c %s freep'
ohosonly testing "0" "$C -s 0 freep $SIZE" "0\n" "" ""
ohosonly testing "12345" "$C -s 12345 freep $SIZE" "12345\n" "" ""
ohosonly testing "1m" "$C -s 1m freep $SIZE" "1048576\n" "" ""
# We can't test against 0 because Android filesystems use an extra 4KiB for
# extended attributes (SELinux). We recreate the file because macOS behavior
# is a bit weird; for some file sizes (12345, in this example) blocks will
# have been allocated that aren't deallocated by the 1g extension.
rm freep; touch freep
ohosonly testing "is sparse" "$C -s 1g freep && [ $(stat -c %b freep) -le 64 ] &&
  echo okay"  	"okay\n" "" ""
ohosonly testing "+" "$C -s 1k freep && $C -s +1k freep $SIZE"  	"2048\n" "" ""
ohosonly testing "-" "$C -s 4k freep && $C -s -1k freep $SIZE"  	"3072\n" "" ""
ohosonly testing "< hit"  	"$C -s 5k freep && $C -s \<4k freep $SIZE" "4096\n" "" ""
ohosonly testing "< miss"  	"$C -s 4k freep && $C -s \<6k freep $SIZE" "4096\n" "" ""
ohosonly testing "> hit"  	"$C -s 3k freep && $C -s \>4k freep $SIZE" "4096\n" "" ""
ohosonly testing "> miss"  	"$C -s 4k freep && $C -s \>2k freep $SIZE" "4096\n" "" ""
ohosonly testing "/" "$C -s 7k freep && $C -s /3k freep $SIZE"  	"6144\n" "" ""
ohosonly testing "%" "$C -s 7k freep && $C -s %3k freep $SIZE"  	"9216\n" "" ""
