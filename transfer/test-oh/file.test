#  jpeg
#  xz
#  Ogg (buncha types)
#  wav audio (buncha types)
#  truetype font/collection
#  Opentype font
#  LLVM IR bitcode
#  PEM certificate
#  pe32
#  BMP
#  Linux perf
#  Android sparse image file
#  Android boot image
#  Android DTB/DTBO
#  Android Binary XML
#  #! shell script
