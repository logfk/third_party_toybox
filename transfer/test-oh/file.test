#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

test_line() {
  ONE="$1"; shift; TWO="\"$FILES\"/$1 | sed 's/^.*: //'"; shift
ohosonly   testcmd "$ONE" "$TWO" "$@"
}

ln -s "$FILES"/java.class symlink
LINK=$(readlink symlink)
ln -s "$FILES"/java.klass dangler
BROKEN=$(readlink dangler)

mkdir directory
ohosonly testing "directory" "$C ." ".: directory\n" "" ""
rmdir directory
touch empty
ohosonly testing "empty" "$C empty" "empty: empty\n" "" ""
rm -f empty

ohosonly testing "script" "$C input | grep -o ' script'" " script\n" "#!/bin/bash\n" ""
ohosonly testing "script with spaces" "$C input | grep -o ' script'" " script\n"    "#!  /bin/bash\n" ""
ohosonly testing "env script" "$C input | sed 's/P/p/g' | egrep -o '(python|script)' | sort"    "python\nscript\n" "#! /usr/bin/env python\n" ""
ohosonly testing "ascii" "$C input" "input: ASCII text\n" "Hello, world!\n" ""
ohosonly testing "utf-8"    "$C \"$FILES\"/utf8/japan.txt | egrep -o 'UTF-8 text' | LANG=c sort"    "UTF-8 text\n" "" ""

# TODO each of these has multiple options we could test
ohosonly testing "java class"    "$C \"$FILES\"/java.class | egrep -o '(Java class|version 53.0)'"   "Java class\nversion 53.0\n" "" ""

echo "cafebabe000000020100000700000003000040000000d9300000000e0100000c8000000200014000000098500000000e" | xxd -r -p > universal
ohosonly testcmd "mach-o universal"    "universal | egrep -o '(Mach-O|universal|x86_64|arm64)' | sort -u"    "Mach-O\narm64\nuniversal\nx86_64\n" "" ""
rm universal

ohosonly test_line "tar file" "tar/tar.tar" "POSIX tar archive (GNU)\n" "" ""
ohosonly testing "gzip data" "$C \"$FILES\"/tar/tar.tgz | grep -o 'gzip compressed data'"      "gzip compressed data\n" "" ""
ohosonly test_line "bzip2 data" "tar/tar.tbz2"    "bzip2 compressed data, block size = 900k\n" "" ""
ohosonly test_line "7z file" "tar/tar.7z" "7-zip archive data, version 0.4\n" "" ""
ohosonly testing "zip file"    "$C $FILES/zip/example.zip | egrep -o '(Zip archive data|at least v1.0 to extract)'"      "Zip archive data\nat least v1.0 to extract\n" "" ""

echo R0lGODlhIAAgAMZHAAAAABYWFiYmJioqKi4uLjIy | base64 -d > gif
ohosonly testing "gif file" "$C gif" "gif: GIF image data, version 89a, 32 x 32\n" "" ""
rm -f gif

# TODO: check in a genuine minimal .dex

echo "6465780a3033350038ca8f6ce910f94e" | xxd -r -p > android.dex
ohosonly testing "Android .dex" "$C android.dex | egrep -o '(dex file|version 035)'"    "dex file\nversion 035\n" "" ""
rm -f android.dex

# These actually test a lot of the ELF code: 32-/64-bit, arm/arm64, PT_INTERP,
# the two kinds of NDK ELF note, BuildID, and stripped/not stripped.
# FILES_DEP: elf/ndk-elf-note-full elf/ndk-elf-note-short elf/fdstatic
ohosonly
toyonly test_line "Android NDK full ELF note" "elf/ndk-elf-note-full"    "ELF shared object, 64-bit LSB arm64, dynamic (/system/bin/linker64), for Android 24, built by NDK r19b (5304403), BuildID=0c712b8af424d57041b85326f0000fadad38ee0a, not stripped\n" "" ""
ohosonly
toyonly test_line "Android NDK short ELF note" "elf/ndk-elf-note-short"    "ELF shared object, 32-bit LSB arm, EABI5, soft float, dynamic (/system/bin/linker), for Android 28, BuildID=da6a5f4ca8da163b9339326e626d8a3c, stripped\n" "" ""
ohosonly
toyonly test_line "ELF static fdpic" "elf/fdstatic"    "ELF executable (fdpic), 32-bit MSB sh, static, stripped\n" "" ""
echo -ne '\x7fELF\00000000000000000000000000000000000000000000' > bad-bits
ohosonly testing "ELF bad bits" "$C bad-bits | egrep -o '(ELF|unknown)'"    "ELF\nunknown\n" "" ""
rm -f bad-bits

ohosonly testing "broken symlink" "$C dangler" "dangler: broken symbolic link to $BROKEN\n" "" ""
ohosonly testing "symlink" "$C symlink" "symlink: symbolic link to $LINK\n" "" ""
ohosonly testing "symlink -h" "$C -h symlink" "symlink: symbolic link to $LINK\n" "" ""
ohosonly testing "symlink -L"    "$C -L symlink | egrep -o '(symlink:|Java class|version 53.0)'"    "symlink:\nJava class\nversion 53.0\n" "" ""

# Some host versions say "-" some "/dev/stdin"...
ohosonly testing "- pipe" "cat $FILES/java.class | $C - | egrep -o '(Java class|version 53.0)'"    "Java class\nversion 53.0\n" "" ""
ohosonly testing "- redirect"    "$C - <$FILES/java.class | egrep -o '(Java class|version 53.0)'"    "Java class\nversion 53.0\n" "" ""

zero_dev="1/5"
[ "$(uname)" == "Darwin" ] && zero_dev="3/3"
ohosonly testing "/dev/zero" "$C /dev/zero" "/dev/zero: character special ($zero_dev)\n" "" ""
ohosonly testing "- </dev/zero" "$C - </dev/zero | grep -ow data" "data\n" "" ""

ohosonly testcmd 'ar' 'input | grep -o " ar archive"' ' ar archive\n'    "$(echo -e '!<arch>\nhello/          0           0     0     644     6         `\nworld')\n" ""
ohosonly testcmd 'cpio' 'input' 'input: ASCII cpio archive (SVR4 with no CRC)\n'    '07070103344745000081A4000003E800' ''

#TODO block fifo socket
