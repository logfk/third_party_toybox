#!/bin/bash

# Test OHOS ping adaptation:
# Large buffer allocation (ping -s 65500)
# Fixes crash when ping uses large packet size

[ -f testing.sh ] && . testing.sh

# ping -c 1 (requires network, root)
ohosonly testing "ping -c 1 localhost" \
  '$C -c 1 -W 1 127.0.0.1 2>&1 | grep -q "127.0.0.1" && echo ok' "ok\n" "" ""

# ping -s <max> (large buffer) - toybox 选项限制 -s 最大 4064
ohosonly testing "ping -s large buffer" \
  '$C -c 1 -s 4064 -W 1 127.0.0.1 2>&1 | grep -q "bytes" && echo ok' "ok\n" "" ""

# ping -4 (IPv4)
ohosonly testing "ping -4" \
  '$C -4 -c 1 -W 1 127.0.0.1 2>&1 | grep -q "127.0.0.1" && echo ok' "ok\n" "" ""
