#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# mcookie 输出 128 位随机数 (format: %016llx%06llx = 22-32 hex digits)
ohosonly testing "hex output" "$C | grep -Eqi '^[0-9a-f]{22,}$' && echo yes" "yes\n" "" ""
ohosonly testing "two differ" "[ \"\$(\$C)\" != \"\$(\$C)\" ] && echo yes" "yes\n" "" ""
