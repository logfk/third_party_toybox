#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# acpi --help (verify command recognizes help)
ohosonly testing "acpi --help" \
  '$C --help >/dev/null 2>&1 && echo ok' "ok\n" "" ""

# acpi -b (batteries, requires /sys/class/power_supply)
ohosonly testing "acpi -b batteries" \
  '$C -b 2>&1 | grep -qi "battery\|No support" && echo ok || echo skip' "ok\n" "" ""

# acpi -a (adapters, requires /sys/class/power_supply)
ohosonly testing "acpi -a adapters" \
  '$C -a 2>&1 | grep -qi "adapter\|No support\|on-line\|off-line" && echo ok || echo skip' "ok\n" "" ""

# acpi -t (temperatures, requires /sys/class/thermal)
ohosonly testing "acpi -t temperatures" \
  '$C -t 2>&1 | grep -qi "thermal\|degree\|No support" && echo ok || echo skip' "ok\n" "" ""

# acpi -c (cooling devices, requires /sys/class/thermal)
ohosonly testing "acpi -c cooling" \
  '$C -c 2>&1 | grep -qi "cooling\|No support" && echo ok || echo skip' "ok\n" "" ""

# acpi -V (show everything)
ohosonly testing "acpi -V all" \
  '$C -V 2>&1 | grep -qi "battery\|adapter\|thermal\|cooling\|No support" && echo ok || echo skip' "ok\n" "" ""
