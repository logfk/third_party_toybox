#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# killall5 can cause board reboot via killall racing with the test harness;
# skip entirely on OHOS board.
SKIP=

# killall5 -l lists signals (safe, no signals sent)
ohosonly testcmd "list signals" \
  "-l 2>&1 | grep -q 'TERM' && echo ok" "ok\n" "" ""

# killall5 -o PID omits that PID; sending signal 0 should not error for own PID
ohosonly testcmd "-o own pid signal 0" \
  "-o \$\$ -s 0 2>&1; echo ok" "ok\n" "" ""

# killall5 with no args should error
ohosonly testcmd "no args" "2>&1; echo \$?" "killall5: Unknown signal: SIG\n1\n" "" ""
