#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

ohosonly testcmd "help" "--help 2>&1 | grep -qi 'deallocvt' && echo ok" "ok\n" "" ""

# no args deallocates all unused VTs (may fail without console)
ohosonly testcmd "no args" "$C 2>&1; echo \$?" "" "" ""
