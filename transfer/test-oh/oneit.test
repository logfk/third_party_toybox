#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# oneit is an init replacement; we can only test help and flag parsing
ohosonly testcmd "help" \
  "--help 2>&1 | grep -qi 'oneit' && echo ok" "ok\n" "" ""

# -n flag appears in help
ohosonly testcmd "-n flag" \
  "--help 2>&1 | grep -q '\-n' && echo ok" "ok\n" "" ""

# -c console device flag appears in help
ohosonly testcmd "-c flag" \
  "--help 2>&1 | grep -q '\-c' && echo ok" "ok\n" "" ""

# -p power off flag appears in help
ohosonly testcmd "-p flag" \
  "--help 2>&1 | grep -q '\-p' && echo ok" "ok\n" "" ""
