#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

ohosonly testcmd "help" "--help 2>&1 | grep -qi 'taskset' && echo ok" "ok\n" "" ""

# no args should fail (needs mask and command)
ohosonly testcmd "no args" "$C 2>/dev/null; echo \$?" "1\n" "" ""

# -p shows affinity of current process
ohosonly testcmd "query self" "$C -p $$ 2>&1 | grep -qi 'affinity' && echo ok" "ok\n" "" ""
