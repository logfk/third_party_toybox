#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# --help always works, no hardware needed
ohosonly testcmd "help" "--help 2>&1 >/dev/null && echo ok" "ok\n" "" ""

# no args should error: needs 1 or 3 arguments
ohosonly testcmd "no args" "2>/dev/null && echo ok || echo fail" "fail\n" "" ""

# -l lists i2c buses from /sys/class/i2c-dev
ohosonly testing "list buses" "$C -l >/dev/null 2>&1 && echo ok || echo skip" "ok\n" "" ""

# -F shows functionality for a bus (needs I2C bus 0)
ohosonly testing "functionality bus 0" "$C -F 0 >/dev/null 2>&1 && echo ok || echo skip" "ok\n" "" ""

# -y -q detect on bus 0 (needs I2C hardware)
ohosonly testing "detect bus 0" "$C -y -q 0 >/dev/null 2>&1 && echo ok || echo skip" "ok\n" "" ""
