#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# wget --help should print usage and exit
ohosonly testing "help flag" \
  '$C --help >/dev/null 2>&1 && echo ok' "ok\n" "" ""

# wget with no args should error (no URL)
ohosonly testing "no args error" \
  '$C >/dev/null 2>&1 && echo BAD || echo ok' "ok\n" "" ""

# unsupported protocol: ftp should be rejected
ohosonly testing "unsupported protocol ftp" \
  '$C ftp://example.com >/dev/null 2>&1 && echo BAD || echo ok' "ok\n" "" ""

# unsupported protocol: ftps should be rejected
ohosonly testing "unsupported protocol ftps" \
  '$C ftps://example.com >/dev/null 2>&1 && echo BAD || echo ok' "ok\n" "" ""

# unsupported protocol: file should be rejected
ohosonly testing "unsupported protocol file" \
  '$C file:///etc/passwd >/dev/null 2>&1 && echo BAD || echo ok' "ok\n" "" ""

# -d flag is recognized (verify via --help, skip connect)
ohosonly testing "debug flag recognized" \
  '$C -d --help >/dev/null 2>&1 && echo ok' "ok\n" "" ""

# --debug long form is recognized (verify via --help)
ohosonly testing "long debug flag recognized" \
  '$C --debug --help >/dev/null 2>&1 && echo ok' "ok\n" "" ""

# -O flag is recognized (verify via --help)
ohosonly testing "output-document flag recognized" \
  '$C -O /dev/null --help >/dev/null 2>&1 && echo ok' "ok\n" "" ""

# --output-document long form is recognized (verify via --help)
ohosonly testing "long output-document flag recognized" \
  '$C --output-document=/dev/null --help >/dev/null 2>&1 && echo ok' "ok\n" "" ""

# -p flag is recognized (verify via --help)
ohosonly testing "post-data flag recognized" \
  '$C -p "data" --help >/dev/null 2>&1 && echo ok' "ok\n" "" ""

# --post-data long form is recognized (verify via --help)
ohosonly testing "long post-data flag recognized" \
  '$C --post-data="data" --help >/dev/null 2>&1 && echo ok' "ok\n" "" ""

# --max-redirect flag is recognized (verify via --help)
ohosonly testing "max-redirect flag recognized" \
  '$C --max-redirect 5 --help >/dev/null 2>&1 && echo ok' "ok\n" "" ""

# -O - should output to stdout (verify via --help, skip connect)
ohosonly testing "output to stdout" \
  '$C -O - --help >/dev/null 2>&1 && echo ok' "ok\n" "" ""

# combined flags: -d -O (verify via --help)
ohosonly testing "combined flags d and O" \
  '$C -d -O /dev/null --help >/dev/null 2>&1 && echo ok' "ok\n" "" ""

# -V/--version if supported
ohosonly testing "version or help works" \
  '$C --help >/dev/null 2>&1 && echo ok' "ok\n" "" ""
