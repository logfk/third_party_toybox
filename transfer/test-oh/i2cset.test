#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# --help always works, no hardware needed
ohosonly testcmd "help" "--help 2>&1 >/dev/null && echo ok" "ok\n" "" ""

# no args should error: needs BUS CHIP ADDR VALUE MODE
ohosonly testcmd "no args" "2>/dev/null && echo ok || echo fail" "fail\n" "" ""

# incomplete args (missing VALUE and MODE) should error
ohosonly testcmd "missing args" "0 0x50 0x00 2>/dev/null && echo ok || echo fail" "fail\n" "" ""

# set on bus 0 chip 0x50 register 0x00 value 0xff byte mode (needs I2C hardware)
ohosonly testing "set bus 0 chip 0x50" "$C -y 0 0x50 0x00 0xff b 2>/dev/null && echo ok || echo skip" "skip\n" "" ""
