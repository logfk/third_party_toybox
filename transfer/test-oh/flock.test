#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# flock 文件锁（OHOS toybox 的 flock 参数解析不支持 command 参数，暂时跳过）
[ -n "$OHOS_TEST" ] && SKIP=$((SKIP+2))
echo x >lockf
ohosonly testing "exclusive lock runs cmd" "$C lockf echo ok" "ok\n" "" ""
ohosonly testing "-n nonblock on free lock" "$C -n lockf echo ok" "ok\n" "" ""
rm -f lockf
