#!/bin/bash

# Test OHOS uptime -p output format fix
# OHOS: ends with \n instead of trailing ", "

[ -f testing.sh ] && . testing.sh

# -p output should NOT end with comma+space
ohosonly testing "-p no trailing comma" \
  '$C -p 2>&1 | grep -c ",$"' \
  "0\n" "" ""

# -p output should start with "up "
ohosonly testing "-p starts with up" \
  '$C -p 2>&1 | grep -c "^up "' \
  "1\n" "" ""

# -p should contain time units
ohosonly testing "-p contains minutes or hours" \
  '$C -p 2>&1 | grep -q -E "minute|hour|day|week" && echo yes' \
  "yes\n" "" ""
