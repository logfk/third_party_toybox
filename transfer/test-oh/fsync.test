#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# fsync flushes file data to disk
ohosonly testcmd "help" \
  "--help 2>&1 | grep -qi 'fsync' && echo ok" "ok\n" "" ""

# no args should error
ohosonly testing "no args" "$C 2>&1; echo \$?" "1\n" "" ""

# sync a real file
echo "test data" > /tmp/test_fsync_00001
ohosonly testcmd "sync file" \
  "$C /tmp/test_fsync_00001 && echo ok" "ok\n" "" ""
rm -f /tmp/test_fsync_00001

# -d flag (fdatasync only)
echo "test data" > /tmp/test_fsync_00002
ohosonly testcmd "-d sync file" \
  "$C -d /tmp/test_fsync_00002 && echo ok" "ok\n" "" ""
rm -f /tmp/test_fsync_00002

# nonexistent file should error
ohosonly testcmd "bad file" \
  "$C /tmp/nonexistent_fsync_file 2>&1; echo \$?" "" "" ""
