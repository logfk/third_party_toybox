#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# makedevs creates device nodes from a device table
ohosonly testcmd "help" \
  "--help 2>&1 | grep -qi 'makedevs' && echo ok" "ok\n" "" ""

# no args should error (needs rootdir)
ohosonly testing "no args" "$C 2>&1; echo \$?" "1\n" "" ""

# create temp dir and a simple device table
mkdir -p /tmp/test_makedevs_00001
echo "null c 0666 0 0 1 3 0 0" > /tmp/test_makedevs_table.txt
ohosonly testcmd "-d table" \
  "$C -d /tmp/test_makedevs_table.txt /tmp/test_makedevs_00001 2>&1 | grep -q 'rootdir' && echo ok" "ok\n" "" ""
rm -rf /tmp/test_makedevs_00001 /tmp/test_makedevs_table.txt

# nonexistent rootdir should error
ohosonly testcmd "bad rootdir" \
  "$C /tmp/nonexistent_rootdir_xyz 2>&1; echo \$?" "" "" ""
