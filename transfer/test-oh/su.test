#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# su --help (verify command recognizes help)
ohosonly testing "su --help" \
  '$C --help >/dev/null 2>&1 && echo ok' "ok\n" "" ""

# su without arguments as non-root (should fail gracefully)
ohosonly testing "su no args" \
  '$C -c id >/dev/null 2>&1 && echo ok || echo skip' "skip\n" "" ""

# su -c command (non-root, expect denial)
ohosonly testing "su -c cmd" \
  '$C root -c "echo test" >/dev/null 2>&1 && echo ok || echo skip' "skip\n" "" ""
