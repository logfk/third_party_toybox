#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# mix requires /dev/mixer (OSS sound); tests skip without hardware
ohosonly testcmd "help" \
  "--help 2>&1 | grep -qi 'mix' && echo ok" "ok\n" "" ""

# no args opens /dev/mixer (will fail if not present)
ohosonly testcmd "no args" \
  "$C 2>&1; echo \$?" "" "" ""

# -d指定不存在的设备
ohosonly testcmd "-d bad device" \
  "$C -d /dev/nonexistent_mixer 2>&1; echo \$?" "" "" ""

# -c channel name (needs /dev/mixer)
ohosonly testcmd "-c channel" \
  "$C -c vol 2>&1; echo \$?" "" "" ""

# -l volume level (needs /dev/mixer)
ohosonly testcmd "-l level" \
  "$C -l 50 2>&1; echo \$?" "" "" ""
