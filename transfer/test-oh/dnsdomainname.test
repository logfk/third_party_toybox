#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

ohosonly testcmd "help" "--help 2>&1 | grep -qi 'dnsdomainname' && echo ok" "ok\n" "" ""

# prints domain part of hostname (may fail on OHOS without domain)
ohosonly testcmd "no args" "2>&1; echo \$?" "dnsdomainname: can't find domain name\n1\n" "" ""
