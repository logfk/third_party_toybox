#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# For reproducibility: TZ=UTC, umask 0002, override ownership and timestamp
export TZ=utc
umask 0002
TAR='$C c --owner root --group root --mtime @1234567890'

# 255 bytes, longest VFS name
LONG=0123456789abcdef0123456789abcdef
LONG=$LONG$LONG$LONG$LONG$LONG$LONG$LONG$LONG
LONG=${LONG:1:255}

# We check both sha1sum (to ensure binary identical output) and list contents.

# Check hash of first N 512 byte frames to ensure result is binary identical.
function SUM()
{
  # Different tars add variable trailing NUL padding (1024 bytes is just
  # minimum) so look at first N 512-byte frames when analyzing header content.
  tee save.dat | head -c $(($1*512)) | sha1sum | sed "s/ .*//"
}

# List tarball contents, converting variable tabs into one space
function LST()
{
  $C tv "$@" | sed 's/[ \t][ \t]*/ /g'
}

# Check that stored empty file is binary identical and decodes as expected.
touch file
SKIP=1 ohosonly testing "store file" "$TAR file | SUM 3"    "2735f3a18d770dd0d7145d76108532f72bef9927\n" "" ""
ohosonly testing "pass file" "$TAR file | LST"    "-rw-rw-r-- root/root 0 2009-02-13 23:31 file\n" "" ""

# Two files from -T list
touch file1 file2
ohosonly testing "-T newline" "$TAR -T input | LST"    "-rw-rw-r-- root/root 0 2009-02-13 23:31 file1\n-rw-rw-r-- root/root 0 2009-02-13 23:31 file2\n" "file1\nfile2\n" ""
ohosonly testing "-T null" "$TAR --null -T input | LST"    "-rw-rw-r-- root/root 0 2009-02-13 23:31 file1\n-rw-rw-r-- root/root 0 2009-02-13 23:31 file2\n" "file1\0file2\0" ""

# User "root" is UID 0 and group "sys" is GID 3 (on Linux, BSD, and Mac),
# inherited from Bell Labs Unix v7

# Note: testing both "tar c" and "tar -c" here.
ohosonly testing "specify UID, fetch GID" "$C -c --owner nobody:65534 --mtime @0 file | LST"    "-rw-rw-r-- nobody/$(stat -c %G file) 0 1970-01-01 00:00 file\n" "" ""
ohosonly testing "fetch UID, specify GID" "$C c --group nobody:65534 --mtime @0 file | LST"    "-rw-rw-r-- $(stat -c %U file)/nobody 0 1970-01-01 00:00 file\n" "" ""

# Large values switch from ascii numbers to a binary format.
ohosonly testing "huge values" "$C c --owner 9999999 --group 8888888 --mtime @0 file | SUM 3"    "396b07fd2f80eeb312462e3bfb7dc1325dc6bcfb\n" "" ""

ohosonly testcmd "longname" "tf $FILES/tar/long_path.tar"    "$(printf 'long file name%86cTRAILING' ' ' | sed 's/ /_/g')\n" "" ""

touch -t 198701231234.56 file
ohosonly testing "pass mtime"    "$C c --owner root --group root file | LST --full-time"    "-rw-rw-r-- root/root 0 1987-01-23 12:34:56 file\n" "" ""

ohosonly testing "adjust mode"    "$C c --owner root --group root --mode a+x file | LST --full-time"    "-rwxrwxr-x root/root 0 1987-01-23 12:34:56 file\n" "" ""

mkdir dir
SKIP=1 ohosonly testing "store dir" "$TAR dir | SUM 3"    "85add1060cfe831ca0cdc945158efe6db485b81e\n" "" ""
ohosonly testing "pass dir" "$TAR dir | LST"    "drwxrwxr-x root/root 0 2009-02-13 23:31 dir/\n" "" ""

# note: does _not_ include dir entry in archive, just file
touch dir/file
SKIP=1 ohosonly testing "store file in dir" "$TAR dir/file | SUM 3"    "d9e7fb3884430d29e7eed0dc04a2593dd260df14\n" "" ""

# Test recursion with one file so filesystem sort order can't change result
SKIP=1 ohosonly testing "store dir and dir/file" "$TAR dir | SUM 3"    "a4e35f87e28c4565b60ba01dbe79e431914f8788\n" "" ""

ohosonly testing "pass dir/file" "$TAR dir | LST"    "drwxrwxr-x root/root 0 2009-02-13 23:31 dir/\n-rw-rw-r-- root/root 0 2009-02-13 23:31 dir/file\n" "" ""

echo boing > dir/that
SKIP=1 ohosonly testing "tar C" "$TAR -C dir that | SUM 3"    "d469d4bc06def2d8808400ba30025ca295d05e4f\n" "" ""

ln dir/file dir/hardlink
SKIP=1 ohosonly testing "store hardlink" "$TAR dir/file dir/hardlink | SUM 3"    "519de8abd1b32debd495a0fc1d96082184abbdcc\n" "" ""

skipnot mkfifo dir/fifo 2>/dev/null
SKIP=1 ohosonly testing "create dir/fifo" "$TAR dir/fifo | SUM 3"    "cad477bd0fc5173d0a43f4774f514035456960e6\n" "" ""

# test L and K records

# 4+96=100 (biggest short name), 4+97=101 (shortest long name)
touch dir/${LONG:1:96} dir/${LONG:1:97}
SKIP=1 ohosonly testing "create long fname" "$TAR dir/${LONG:1:97} dir/${LONG:1:96} | SUM 3"    "d70018505fa5df19ae73498cfc74d0281601e42e\n" "" ""

# MacOS X has different symlink permissions, skip these tests there
[ "$(uname)" == Darwin ] && SKIP=999

  # / and .. only stripped from name, not symlink target.
  ln -s ../name.././.. dir/link
  SKIP=1 ohosonly   testing "create symlink" "$TAR dir/link | SUM 3"      "f841bf9d757c655c5d37f30be62acb7ae24f433c\n" "" ""

  ln dir/link dir/hlink
  SKIP=1 ohosonly   testing "create hardlink to symlink" "$TAR dir/link dir/hlink | SUM 3"      "de571a6dbf09e1485e513ad13a178b1729267452\n" "" ""

  ln -s dir/${LONG:1:96} dir/lshort
  ln -s dir/${LONG:1:97} dir/llong
  SKIP=1 ohosonly   testing "create long symlink" "$TAR dir/lshort dir/llong | SUM 3"      "07eaf397634b5443dbf2d3ec38a4302150fcfe82\n" "" ""

  skipnot ln -s $LONG dir/${LONG:5} 2>/dev/null
  SKIP=1 ohosonly   testing "create long->long" "$TAR dir/${LONG:5} | SUM 7"      "b9e24f53e27496c5125445230d201b4a36ff7398\n" "" ""

  # absolute and relative link names, broken and not
  ln -s file dir/linkok
  SKIP=1 ohosonly   testing "create symlink" "$TAR dir/linkok | SUM 3"      "f5669cfd179ddcdd5ca9f8a1561a99e11e0a08b1\n" "" ""

SKIP=0 # End of tests that don't match MacOS symlink permissions

symlink_perms=lrwxrwxrwx
[ "$(uname)" == "Darwin" ] && symlink_perms=lrwxrwxr-x

ln -s /dev/null dir/linknull
ohosonly testing "pass absolute symlink" "$TAR dir/linknull | LST"    "$symlink_perms root/root 0 2009-02-13 23:31 dir/linknull -> /dev/null\n" "" ""

ln -s rel/broken dir/relbrok
ohosonly testing "pass broken symlink" "$TAR dir/relbrok | LST"    "$symlink_perms root/root 0 2009-02-13 23:31 dir/relbrok -> rel/broken\n" "" ""

ln -s /does/not/exist dir/linkabsbrok
ohosonly testing "pass broken absolute symlink" "$TAR dir/linkabsbrok | LST"    "$symlink_perms root/root 0 2009-02-13 23:31 dir/linkabsbrok -> /does/not/exist\n"    "" ""

nulldev=1,3 # devtmpfs values
[ "$(uname)" == "Darwin" ] && nulldev=3,2

ohosonly testing "pass /dev/null"    "$C c --mtime @0 /dev/null 2>/dev/null | LST"    "crw-rw-rw- $(stat -c %U/%G /dev/null) $nulldev 1970-01-01 00:00 dev/null\n"    "" ""
ohosonly testing "--absolute-names"    "$C c --mtime @0 --absolute-names /dev/null 2>/dev/null | LST"    "crw-rw-rw- $(stat -c %U/%G /dev/null) $nulldev 1970-01-01 00:00 /dev/null\n"   "" ""

# compression types
ohosonly testing "autodetect gzip" 'LST -f "$FILES"/tar/tar.tgz'    "drwxr-x--- enh/eng 0 2017-05-13 01:05 dir/\n-rw-r----- enh/eng 12 2017-05-13 01:05 dir/file\n"    "" ""

ohosonly testing "manually specify bz2" 'LST -jf "$FILES"/tar/tar.tbz2'    "drwxr-x--- enh/eng 0 2017-05-13 01:05 dir/\n-rw-r----- enh/eng 12 2017-05-13 01:05 dir/file\n"    "" ""

# -I
ohosonly testing "-I gzip c" "$TAR -Igzip file | file - | grep -o 'gzip compressed'"    "gzip compressed\n" "" ""
ohosonly testing "-I gzip t" 'LST -Igzip -f "$FILES"/tar/tar.tgz'    "drwxr-x--- enh/eng 0 2017-05-13 01:05 dir/\n-rw-r----- enh/eng 12 2017-05-13 01:05 dir/file\n"    "" ""

skipnot mknod -m 660 dir/char c 12 34 2>/dev/null
NOSPACE=1 testing "character special" "$C --mtime @0 -cf test.tar dir/char && rm -f dir/char && $C xf test.tar && ls -l --full-time dir/char"    "crw-rw---- 1 root root 12,  34 1970-01-01 00:00:00.000000000 +0000 dir/char\n"   "" ""

skipnot mknod -m 660 dir/block b 23 45 2>/dev/null
NOSPACE=1 testing "block special" "$C --mtime @0 -cf test.tar dir/block && rm -f dir/block && $C xf test.tar && ls -l --full-time dir/block"    "brw-rw---- 1 root root 23,  45 1970-01-01 00:00:00.000000000 +0000 dir/block\n"   "" ""

skipnot chown nobody:nogroup dir/file 2>/dev/null
SKIP=1 ohosonly testing "ownership" "$TAR dir/file | SUM 3"    "2d7b96c7025987215f5a41f10eaa84311160afdb\n" "" ""

mkdir -p dd/sub/blah &&
tar cf test.tar dd/sub/blah &&
rm -rf dd/sub &&
skipnot ln -s ../.. dd/sub
ohosonly
toyonly testing "symlink out of cwd"    "$C xf test.tar 2> /dev/null || echo yes ; [ ! -e dd/sub/blah ] && echo yes"    "yes\nyes\n" "" ""

# If not root can't preserve ownership, so don't try yet.

ohosonly testing "extract dir/file from tar"    "$C xvCf dd $FILES/tar/tar.tar && stat -c '%A %Y %n' dd/dir dd/dir/file"    "dir/\ndir/file\ndrwxr-x--- 1494637555 dd/dir\n-rw-r----- 1494637555 dd/dir/file\n"    "" ""

ohosonly testing "extract dir/file from tgz (autodetect)"    "$C xvCf dd $FILES/tar/tar.tgz && stat -c '%A %Y %n' dd/dir dd/dir/file"    "dir/\ndir/file\ndrwxr-x--- 1494637555 dd/dir\n-rw-r----- 1494637555 dd/dir/file\n"    "" ""

ohosonly
toyonly testing "cat tgz | extract dir/file (autodetect)"    "cat $FILES/tar/tar.tgz | $C xvC dd && stat -c '%A %Y %n' dd/dir dd/dir/file"    "dir/\ndir/file\ndrwxr-x--- 1494637555 dd/dir\n-rw-r----- 1494637555 dd/dir/file\n"    "" ""

ohosonly testing "extract dir/file from tbz2 (autodetect)"    "$C xvCf dd $FILES/tar/tar.tbz2 && stat -c '%A %Y %n' dd/dir dd/dir/file"    "dir/\ndir/file\ndrwxr-x--- 1494637555 dd/dir\n-rw-r----- 1494637555 dd/dir/file\n"    "" ""

ohosonly
toyonly testing "cat tbz | extract dir/file (autodetect)"    "cat $FILES/tar/tar.tbz2 | $C xvC dd && stat -c '%A %Y %n' dd/dir dd/dir/file"    "dir/\ndir/file\ndrwxr-x--- 1494637555 dd/dir\n-rw-r----- 1494637555 dd/dir/file\n"    "" ""

mkdir path && ln -s "$(which gzip)" "$(which tar)" path/ && [ -x path/gzip ] ||
  SKIP=$((SKIP+1))
ohosonly
toyonly testing "autodetect falls back to gzip -d when no zcat"    "PATH=path; $C tf $FILES/tar/tar.tgz" "dir/\ndir/file\n" "" ""
rm -rf path

# TODO: run sparse tests on tmpfs mount? (Request filesystem type?)
# Only run sparse tests if filesystem can handle sparse files @4k granularity
dd if=/dev/zero bs=4k count=1 seek=1 of=blah.img 2>/dev/null
[ $(du blah.img | sed 's/[ \t].*//') -ne 4 ] && SKIP=999
rm -f blah.img
[ "$(uname)" == "Darwin" ] && SKIP=999

  yes | head -n $((1<<18)) > bang
  {
    dd bs=$((1<<16)) count=1 status=none
    dd bs=8192 seek=14 count=1 status=none
    dd bs=4096 seek=64 count=5 status=none
  } < bang > fweep
  SKIP=1 ohosonly   testing "sparse without overflow" "$TAR --sparse fweep | SUM 3"      "50dc56c3c7eed163f0f37c0cfc2562852a612ad0\n" "" ""
  rm bang fweep

  for i in 1 3 5 7 9 14 27 36 128 256 300 304
  do
    dd if=/dev/zero of=fweep bs=65536 seek=$i count=1 2>/dev/null
  done
  SKIP=1 ohosonly   testing "sparse single overflow" "$TAR --sparse fweep | SUM 6"      "81d59c3a7470201f92d60e63a43318ddde893f6d\n" "" ""
  rm fweep

  for i in $(seq 8 3 200)
  do
    dd if=/dev/zero of=fweep bs=65536 seek=$i count=1 2>/dev/null
    dd if=/dev/zero of=fweep2 bs=65536 seek=$i count=1 2>/dev/null
  done
  truncate -s 20m fweep2
  SKIP=1 ohosonly   testing "sparse double overflow" "$TAR --sparse fweep | SUM 7"      "024aacd955e45f89bafedb3f37c8d39b4d556471\n" "" ""

  tar c --sparse fweep > fweep.tar
  rm fweep
  SKIP=1 ohosonly   testing "sparse extract" "$C xf fweep.tar && $TAR --sparse fweep | SUM 4"      "b949d3a3b4c6457c873f1ea9918fd9029c5ed4b3\n" "" ""
ohosonly   testing "sparse tvf"      "$C tvf fweep.tar | grep -wq 13172736 && echo right size" "right size\n"      "" ""
  rm fweep fweep.tar

  tar c --sparse fweep2 > fweep2.tar
  rm fweep2
  SKIP=1 ohosonly   testing "sparse extract hole at end" "$C xf fweep2.tar && $TAR --sparse fweep2 | SUM 4"      "807664bcad0e827793318ff742991d6f006b2127\n" "" ""
  rm fweep2 fweep2.tar

ohosonly   testcmd 'extract obsolete sparse format'      'xf "$FILES"/tar/oldsparse.tgz && sha1sum hello-sparse.c | head -c 12'      '9714dc7ac8c0' '' ''
  rm -f hello-sparse.c

SKIP=0 # End of sparse tests

mkdir -p links
touch links/orig
ln links/{orig,link1}
ln links/{orig,link2}
ohosonly testcmd 'links' '-cf test.tar links' '' '' ''
rm -rf links

mkdir links
for i in {0..12}; do touch links/orig$i; ln links/{orig,link}$i; done
ohosonly testcmd 'links2' '-cf test.tar links' '' '' ''
rm -rf links

install -m 000 -d folder/skip/oof &&
ohosonly testcmd 'exclude' '--exclude skip -cvf tar.tar folder && echo yes'    'folder/\nyes\n' '' ''
rm -rf folder tar.tar

mkdir -p one/two; echo hello > one/two/three; tar czf test.tar one/two/three
rm one/two/three; mkdir one/two/three
ohosonly testcmd 'replace dir with file' '-xf test.tar && cat one/two/three'    'hello\n' '' ''
rm -rf one test.tar

mkdir ..dotsdir
SKIP=1 ohosonly testing "create ..dotsdir" "$TAR ..dotsdir | SUM 3"    "62ff23c9b427020331992b9bc71f082099c1411f\n" "" ""

ohosonly testing "pass ..dotsdir" "$TAR ..dotsdir | LST"    "drwxrwxr-x root/root 0 2009-02-13 23:31 ..dotsdir/\n" "" ""
rmdir ..dotsdir

mkdir -p one/two/three/four/five
touch one/two/three/four/five/six
ohosonly testing "--strip" "$TAR one | $C t --strip=2 --show-transformed | grep six"    "three/four/five/six\n" "" ""

# toybox tar --xform depends on toybox sed
[ -z "$TEST_HOST" ] && ! sed --tarxform '' </dev/null 2>/dev/null && SKIP=99

mkdir uno
ln -s tres uno/dos
touch uno/tres
ln uno/tres uno/quatro
LL() { LST --show-transformed-names $XX | sed 's/^.* 23:31 //'; }
TT() { $TAR --no-recursion uno uno/{dos,tres,quatro} "$@" | LL; }
ohosonly testing 'xform S'    "TT --xform 's/uno/one/S;s/dos/two/S;s/tres/three/S;s/quatro/four/S'"    "one/\none/two -> tres\none/three\none/four link to one/three\n" "" ""

ohosonly testing 'xform flags=rh starts with all disabled'    "TT --xform 's/uno/one/;flags=rh;s/dos/two/;s/tres/three/;s/quatro/four/'"    "one/\none/two -> tres\none/three\none/four link to one/three\n" "" ""

ohosonly testing 'xform flags=rHhsS toggles'    "TT --xform 's/uno/one/;flags=rHhsS;s/dos/two/;s/tres/three/;s/quatro/four/'"   "one/\none/two -> tres\none/three\none/four link to one/three\n" "" ""

ohosonly testing 'xform flags= is not a delta from previous'    "TT --xform 'flags=s;flags=rh;s/uno/one/;s/dos/two/;s/tres/three/;s/quatro/four/'"    "one/\none/two -> tres\none/three\none/four link to one/three\n" "" ""

ohosonly testing 'xform H'    "TT --xform 'flags=rsH;s/uno/one/;s/dos/two/;s/tres/three/;s/quatro/four/'"    "one/\none/two -> three\none/three\none/four link to uno/tres\n" "" ""

ohosonly testing 'xform R'    "TT --xform 'flags=rshR;s/uno/one/;s/dos/two/;s/tres/three/;s/quatro/four/'"    "uno/\nuno/dos -> three\nuno/tres\nuno/quatro link to one/three\n" "" ""

ohosonly testing "xform path" "$TAR one --xform=s@three/four/@zero@ | $C t | grep six"    "one/two/zerofive/six\n" "" ""

ohosonly testing "xform trailing slash special case"    "$TAR --xform 's#^.+/##x' one/two/three/four/five | $C t" 'five/\nsix\n' '' ''

# The quoting works because default IFS splits on whitepace not ;
ohosonly testing "xform extract all"    "XX='--xform s/uno/one/;s/dos/two/;s/tres/three/;s/quatro/four/' TT"    'one/\none/two -> three\none/three\none/four link to one/three\n' '' ''

ohosonly testing 'xform extract S'    "XX='--xform s/uno/one/S;s/dos/two/S;s/tres/three/S;s/quatro/four/S' TT"    "one/\none/two -> tres\none/three\none/four link to one/three\n" "" ""

ohosonly testing 'xform extract H'    "XX='--xform flags=rs;s/uno/one/;s/dos/two/;s/tres/three/;s/quatro/four/' TT"   "one/\none/two -> three\none/three\none/four link to uno/tres\n" "" ""

ohosonly testing 'xform extract R'    "XX='--xform flags=sh;s/uno/one/;s/dos/two/;s/tres/three/;s/quatro/four/' TT"   "uno/\nuno/dos -> three\nuno/tres\nuno/quatro link to one/three\n" "" ""

rm -rf uno
SKIP=0
rm -rf one

SKIP=1 ohosonly testing '-P' "$TAR -P --no-recursion -C / /// .. | SUM 3"    "a3e94211582da121845d823374d8f41ead62d7bd\n" "" ""

SKIP=1 ohosonly testing 'without -P' "$TAR --no-recursion -C / /// .. 2>/dev/null | SUM 3"    "077d03243e247b074806904885e6da272fd5857a\n" "" ""

# Wildcards: --exclude, include (create/extract * cmdline/recursive)
# --anchored, --wildcards, --wildcards-match-slash
# --no-* versions of each. Span coverage, switching on/off...

#pattern a.c
#  abcd dabc a/c da/c
#  top/*

mkdir sub && cd sub && mkdir -p a da top/a top/da &&
touch abcd dabc a/c da/c top/abcd top/dabc top/a/c top/da/c &&
$TAR -f ../sub.tar abcd dabc a da top && cd .. || exit 1

# TODO I have not made wildcard state changes positional.

ohosonly testing 'wildcards do not affect creation cmdline args'    '$TAR -C sub --wildcards a.cd abcd dabc a da top 2>/dev/null | cmp - sub.tar'    '' '' ''

ohosonly testing 'creation --exclude --no-wildcards'   '$TAR -C sub --no-wildcards --exclude=d?bc abcd dabc | LL'    'abcd\ndabc\n' '' ''


ohosonly testing 'creation --wildcards --exclude'   '$TAR -C sub --wildcards --exclude=d?bc abcd dabc | LL'    'abcd\n' '' ''

# TODO: do we need to set DIRTREE_BREADTH at top level? Come up with test if so.
mkdir sub2
touch sub2/{ephebe,klatch,djelibeybi}
ohosonly testing 'tsort' '$TAR -c sub2 --sort=name | $C t'    'sub2/\nsub2/djelibeybi\nsub2/ephebe\nsub2/klatch\n' '' ''

touch file
ohosonly testing './file bug' '$C c ./file > tar.tar && $C t ./file < tar.tar'    './file\n' '' ''

skipnot [ $(id -u) -ne 0 ]  # Root defaults to -p
ohosonly testing 'honor umask'    'umask 0022 && rm -rf dir && mkdir dir && $C xf $FILES/tar/dir.tar && stat -c%A dir dir/file'    'drwxr-xr-x\n-rwxr-xr-x\n' '' ''
ohosonly testing 'extract changes directory permissions'    'umask 0022 && rm -rf dir && mkdir dir && umask 0 && $C xf $FILES/tar/dir.tar && stat -c%A dir dir/file'    'drwxrwxrwx\n-rwxrwxrwx\n' '' ''
ohosonly testing '-p overrides umask'    'umask 0022 && rm -rf dir && mkdir dir && $C xpf $FILES/tar/dir.tar && stat -c%A dir dir/file'    'drwxrwxrwx\n-rwxrwxrwx\n' '' ''

if false
then
# Sequencing issues that leak implementation details out the interface
ohosonly testing "what order are --xform, --strip, and --exclude processed in?"
ohosonly testing "--xform vs ../ removal and adding / to dirs"

chmod 700 dir
tar cpf tar.tgz dir/file
#chmod 700 dir
#tar xpf file
#ls -ld dir/file

# restore ownership of file, dir, and symlink

# merge add_to_tar and write_longname,
# filter, incl or excl and anchored/wildcards

# extract file not under cwd
# exclusion defaults to --no-anchored and --wildcards-match-slash
#  both incl and excl

# catch symlink overwrite
# add dir with no trailing slash
# don't allow hardlink target outside cwd
# extract dir/file without dir in tarball
# create with and without each flag
# --owner --group --numeric-owner
# extract with and without each flag
# --owner 0 --group 0
# set symlink owner
# >256 hardlink inodes
#   // remove leading / and any .. entries from saved name
#  // exclusion defaults to --no-anchored and --wildcards-match-slash
# //bork blah../thing blah/../thing blah/../and/../that blah/.. ../blah
# $C tv --owner --group --mtime
# extract file within dir date correct
# name ending in /.. or just ".." as a name


fi

rm -f save.dat
