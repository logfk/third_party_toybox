#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# lspci reads from /sys/bus/pci/devices; skip if not available
ohosonly testcmd "help" \
  "--help 2>&1 | grep -qi 'lspci' && echo ok" "ok\n" "" ""

# basic lspci (may produce no output if no PCI devices)
ohosonly testcmd "basic" \
  "$C 2>&1; echo ok" "ok\n" "" ""

# -e full class display
ohosonly testcmd "-e flag" \
  "$C -e 2>&1; echo ok" "ok\n" "" ""

# -k kernel driver
ohosonly testcmd "-k flag" \
  "$C -k 2>&1; echo ok" "ok\n" "" ""

# -m machine parseable
ohosonly testcmd "-m flag" \
  "$C -m 2>&1; echo ok" "ok\n" "" ""
