#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# lspci reads from /sys/bus/pci/devices; skip if not available
ohosonly testcmd "help" \
  "--help 2>&1 >/dev/null && echo ok" "ok\n" "" ""

# basic lspci (may fail on OHOS without PCI bus)
ohosonly testcmd "basic" \
  ">/dev/null 2>&1 && echo ok || echo skip" "skip\n" "" ""

# -e full class display
ohosonly testcmd "-e flag" \
  "-e >/dev/null 2>&1 && echo ok || echo skip" "skip\n" "" ""

# -k kernel driver
ohosonly testcmd "-k flag" \
  "-k >/dev/null 2>&1 && echo ok || echo skip" "skip\n" "" ""

# -m machine parseable
ohosonly testcmd "-m flag" \
  "-m >/dev/null 2>&1 && echo ok || echo skip" "skip\n" "" ""
