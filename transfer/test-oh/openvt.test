#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# openvt requires root and a real VT console; tests skip without
ohosonly testcmd "help" \
  "--help 2>&1 | grep -qi 'openvt' && echo ok" "ok\n" "" ""

# no args should error
ohosonly testing "no args" "$C 2>&1; echo \$?" "1\n" "" ""

# -c NUM flag (specify VT number)
ohosonly testcmd "-c flag" \
  "$C -c 1 /bin/true 2>&1; echo \$?" "" "" ""

# -s switch to new VT
ohosonly testcmd "-s flag" \
  "$C -s /bin/true 2>&1; echo \$?" "" "" ""

# -w wait for command
ohosonly testcmd "-w flag" \
  "$C -w /bin/true 2>&1; echo \$?" "" "" ""
