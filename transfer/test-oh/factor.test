#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

ohosonly
toyonly testing "-32" "$C -32" "-32: -1 2 2 2 2 2\n" "" ""
ohosonly
toyonly testing "0" "$C 0" "0: 0\n" "" ""
ohosonly
toyonly testing "1" "$C 1" "1: 1\n" "" ""
ohosonly testing "2" "$C 2" "2: 2\n" "" ""
ohosonly testing "3" "$C 3" "3: 3\n" "" ""
ohosonly testing "4" "$C 4" "4: 2 2\n" "" ""
ohosonly testing "10000000017" "$C 10000000017"          "10000000017: 3 3 3 7 7 7 1079797\n" "" ""
ohosonly testing "10000000018" "$C 10000000018"          "10000000018: 2 131 521 73259\n" "" ""
ohosonly testing "10000000019" "$C 10000000019"          "10000000019: 10000000019\n" "" ""

ohosonly testing "3 6 from stdin" "$C" "3: 3\n6: 2 3\n" "" "3 6"
ohosonly testing "stdin newline" "$C" "3: 3\n6: 2 3\n" "" "3\n6\n"

[ -n "$OHOS_TEST" ] && SKIP=$((SKIP+1))
toyonly testing "-h" "$C -h $(((1<<63)-26))"    "9223372036854775782: 2 3^4 17 23 319279 456065899\n" "" ""
[ -n "$OHOS_TEST" ] && SKIP=$((SKIP+1))
toyonly testing "-x" "$C -x $(((1<<63)-20))"    "7fffffffffffffec: 2 2 3 283 43f2ba978e663\n" "" ""

