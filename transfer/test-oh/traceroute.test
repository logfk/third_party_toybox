#!/bin/bash

# Test OHOS traceroute adaptation:
# Fixes traceroute -s (source address) by setting
# sin_family = AF_INET / sin6_family = AF_INET6 before bind()

[ -f testing.sh ] && . testing.sh

# traceroute help
ohosonly testing "traceroute help" \
  '$C >/dev/null 2>&1; [ $? -eq 127 ] || echo ok' "ok\n" "" ""

# traceroute -s with source address (requires root & network)
ohosonly testing "traceroute -s" \
  '$C -s 127.0.0.1 127.0.0.1 >/dev/null 2>&1 && echo ok || echo skip' "skip\n" "" ""

# traceroute -4 (IPv4, requires root & network)
ohosonly testing "traceroute -4" \
  '$C -4 -s 127.0.0.1 127.0.0.1 >/dev/null 2>&1 && echo ok || echo skip' "skip\n" "" ""
