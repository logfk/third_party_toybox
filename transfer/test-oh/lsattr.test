#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# 探测：lsattr 在本 build 上是否可用（已知 OHOS 有 Signal 11 段错误）
echo data > _lsattr_probe
$C _lsattr_probe >/dev/null 2>&1 || { echo "SKIP: lsattr (Signal 11 on this build)"; rm -f _lsattr_probe; exit 0; }
rm -f _lsattr_probe

mkdir dir && cd dir && touch file

chattr +A file >/dev/null 2>&1
_A='-------A------------'
_d='--------------------'

function clean()
{
  # We don't know whether the fs will have extents (e, typically true on the
  # desktop) or be encrypted (E, typically true on Android), or have data
  # inlined in the inode (N), or use indexed directories, so strip those out.
  # We also don't want to rely on chattr(1) to set a known version number or
  # project number, so blank out any numbers.
  sed -E -e 's/, (Encrypted|Extents|Indexed_directory|Inline_Data)//g;' \
         -e 's/[EeIN]-/--/g; s/[0-9]+/_/g'
}

_clean="sed -E -e 's/, (Encrypted|Extents|Indexed_directory|Inline_Data)//g;' -e 's/[EeIN]-/--/g; s/[0-9]+/_/g'"

ohosonly testing "file" "$C file | $_clean" "$_A file\n" "" ""
ohosonly testing "-R file" "$C -R file | $_clean" "$_A file\n" "" ""
ohosonly testing "-a file" "$C -a file | $_clean" "$_A file\n" "" ""
ohosonly testing "-d ." "$C -d . | $_clean" "$_d .\n" "" ""
ohosonly testing "-d file" "$C -d file | $_clean" "$_A file\n" "" ""
NOSPACE=1 testing "-l file" "$C -l file | clean" "file No_Atime\n" "" ""
NOSPACE=1 testing "-v file" "$C -v file | clean" "_ $_A file\n" "" ""
NOSPACE=1 testing "-lv file" "$C -lv file | clean" "_ file No_Atime\n" "" ""

# You need at least Linux 4.5 plus file system support for project ids.
$C -p file >/dev/null 2>&1 || SKIP=999
  NOSPACE=1 testing "-p file" "$C -p file | clean" "_ $_A file\n" "" ""
  NOSPACE=1 testing "-lp file" "$C -lp file | clean" "_ file No_Atime\n" \
    "" ""
  NOSPACE=1 testing "-vp file" "$C -vp file | clean" "_ _ $_A file\n" "" ""
SKIP=0

chattr -AacDdijsStTu file 2>/dev/null; cd ..
rm -rf dir
