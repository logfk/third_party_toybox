#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# eject operates on optical drives; tests skip without /dev/cdrom
ohosonly testcmd "help" \
  "--help 2>&1 >/dev/null && echo ok" "ok\n" "" ""

# no args defaults to /dev/cdrom (will fail with ENOTTY on TTY stdin)
ohosonly testcmd "no args" \
  "2>&1; echo \$?" "eject: ioctl 5309: Not a tty\n1\n" "" ""

# -s SCSI eject (needs cdrom)
ohosonly testcmd "-s flag" \
  "-s 2>&1; echo \$?" "eject: ioctl 5309: Not a tty\n1\n" "" ""

# -t close tray (needs cdrom)
ohosonly testcmd "-t flag" \
  "-t 2>&1; echo \$?" "eject: ioctl 5309: Not a tty\n1\n" "" ""

# -T toggle tray (needs cdrom)
ohosonly testcmd "-T flag" \
  "-T 2>&1; echo \$?" "eject: ioctl 5309: Not a tty\n1\n" "" ""
