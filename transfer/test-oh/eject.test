#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# eject operates on optical drives; tests skip without /dev/cdrom
ohosonly testcmd "help" \
  "--help 2>&1 | grep -qi 'eject' && echo ok" "ok\n" "" ""

# no args defaults to /dev/cdrom (will fail if not present)
ohosonly testcmd "no args" \
  "$C 2>&1; echo \$?" "" "" ""

# -s SCSI eject (needs cdrom)
ohosonly testcmd "-s flag" \
  "$C -s 2>&1; echo \$?" "" "" ""

# -t close tray (needs cdrom)
ohosonly testcmd "-t flag" \
  "$C -t 2>&1; echo \$?" "" "" ""

# -T toggle tray (needs cdrom)
ohosonly testcmd "-T flag" \
  "$C -T 2>&1; echo \$?" "" "" ""
