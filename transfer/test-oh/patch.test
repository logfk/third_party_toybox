#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

SKIP=1 ohosonly testing "dry run doesn't create file"    "$C --dry-run >/dev/null && [ ! -e bork ] && echo yes" "yes\n" "" "
--- /dev/null
+++ bork
@@ -0,0 +1,1 @@
+one
"

ohosonly testing "create file" "$C >/dev/null && cat bork" "one\ntwo\nthree\n" "" "
--- /dev/null
+++ bork
@@ -0,0 +1,3 @@
+one
+two
+three
"

ohosonly testing "insert in middle" "$C > /dev/null && cat bork"    "one\nfour\ntwo\nthree\n" "" "
--- bork
+++ bork
@@ -1,3 +1,4 @@
 one
+four
 two
 three
"
ohosonly testing "append at end" "$C > /dev/null && cat bork"    "one\nfour\ntwo\nthree\nfive\nsix\n" "" "
--- bork
+++ bork
@@ -2,3 +2,5 @@
 four
 two
 three
+five
+six
"
ohosonly testing "insert at start" "$C > /dev/null && cat bork"    "seven\none\nfour\ntwo\nthree\nfive\nsix\n" "" "
--- bork
+++ bork
@@ -1,3 +1,4 @@
+seven
 one
 four
 two
"
ohosonly testing "delete at end" "$C > /dev/null && cat bork"    "seven\none\nfour\ntwo\nthree\nfive\n" "" "
--- bork
+++ bork
@@ -4,4 +4,3 @@
 two
 three
 five
-six
"

ohosonly testing "delete at start" "$C > /dev/null && cat bork"    "four\ntwo\nthree\nfive\n" "" "
--- bork
+++ bork
@@ -1,5 +1,3 @@
-seven
-one
 four
 two
 three
"

ohosonly testing "filter timestamps" "$C > /dev/null && cat bork"    "four\ntwo\nthree\neight\nfive\n" "" "
--- bork	2019-12-20 16:54:35.735630973 -0600
+++ bork	2019-12-20 16:57:03.083625706 -0600
@@ -1,4 +1,5 @@
 four
 two
 three
+eight
 five
"

ohosonly testing "quoted name" "$C > /dev/null && cat 'fruit bat'"    "hello\n" "" '
--- /dev/null
+++ "fruit ba\164"
@@ -0,0 +1 @@
+hello
'

ohosonly testing "bad quote" "$C 2>&1" "" "" '--- "filename'

SKIP=1 ohosonly testing "dry run doesn't delete file"    "$C --dry-run > /dev/null && [ -e 'fruit bat' ] && echo yes" "yes\n" "" '
--- "fruit bat"
+++ /dev/null
@@ -1 +0,0 @@
-hello
'

ohosonly testing "delete file"    "$C > /dev/null && [ ! -e 'fruit bat' ] && echo yes" "yes\n" "" '
--- "fruit bat"
+++ /dev/null
@@ -1 +0,0 @@
-hello
'

# todo bork bork2

# We hit a bug, test the bugfix.
SKIP=1 ohosonly testing "fuzz" "$C > /dev/null && cat input"  "blah blah
 */
package org.yaml.snakeyaml.representer;

import java.util.ArrayList;
import java.util.Arrays;
import java.util.Collections;
import java.util.Iterator;
" "blah blah
 */
package org.yaml.snakeyaml.representer;

import java.beans.IntrospectionException;
import java.util.ArrayList;
import java.util.Arrays;
import java.util.Collections;
import java.util.Iterator;
" "--- a/x/input
+++ b/x/input
@@ -15,7 +15,6 @@
  */
 package org.yaml.snakeyaml.representer;

-import java.beans.IntrospectionException;
 import java.util.ArrayList;
 import java.util.Arrays;
 import java.util.Iterator;
"

# === Flag tests for untested flags ===

# -p: strip path components
mkdir -p _patch_dirstrip
echo "oldcontent" > _patch_dirstrip/_patch_tfile
ohosonly testing "patch -p0 strip none" \
  '$C -p0 -d _patch_dirstrip >/dev/null && cat _patch_dirstrip/_patch_tfile' "newcontent\n" "" \
"--- _patch_tfile
+++ _patch_tfile
@@ -1 +1 @@
-oldcontent
+newcontent
"
rm -rf _patch_dirstrip

# -R: reverse (undo) a patch
echo "linetwo" > _patch_revfile
ohosonly testing "patch -R reverse" \
  '$C -R >/dev/null && cat _patch_revfile' "lineone\n" "" \
"--- _patch_revfile
+++ _patch_revfile
@@ -1 +1 @@
-lineone
+linetwo
"
rm -f _patch_revfile

# -d: apply patch from different directory
mkdir -p _patch_subdir
echo "before" > _patch_subdir/_patch_dfile
ohosonly testing "patch -d directory" \
  '$C -d _patch_subdir -p0 >/dev/null && cat _patch_subdir/_patch_dfile' "after\n" "" \
"--- _patch_dfile
+++ _patch_dfile
@@ -1 +1 @@
-before
+after
"
rm -rf _patch_subdir

# -i: read patch from specified file
echo "modified" > _patch_ifile
printf "--- _patch_ifile\n+++ _patch_ifile\n@@ -1 +1 @@\n-modified\n+fromifile\n" > _patch_idata
ohosonly testing "patch -i input file" \
  '$C -i _patch_idata >/dev/null && cat _patch_ifile' "fromifile\n" "" ""
rm -f _patch_ifile _patch_idata
