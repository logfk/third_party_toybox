#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

ohosonly testing "/-only" "$C ///////" "/\n" "" ""
ohosonly testing "trailing /" "$C a//////" ".\n" "" ""
ohosonly testing "combined" "$C /////a///b///c///d/////" "/////a///b///c\n" "" ""
ohosonly testing "/a/" "$C /////a///" "/\n" "" ""
ohosonly testing "multiple" "$C hello/a world/b" "hello\nworld\n" "" ""
