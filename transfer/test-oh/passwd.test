#!/bin/bash

# Test OHOS passwd adaptation:
# Conditionally frees encrypted password memory only when
# CFG_TOYBOX_FREE is set and -l flag is present

[ -f testing.sh ] && . testing.sh

# passwd --help (verify command exists)
ohosonly testing "passwd help" \
  '$C --help 2>&1 | head -1 | grep -q "usage\|Usage\|passwd" && echo ok' "ok\n" "" ""

# passwd -l (lock account, requires root)
ohosonly testing "passwd -l lock" \
  '$C -l root 2>/dev/null || echo denied' "denied\n" "" ""

# passwd -u (unlock, requires root)
ohosonly testing "passwd -u unlock" \
  '$C -u root 2>/dev/null || echo denied' "denied\n" "" ""

# passwd -d (delete password, requires root)
ohosonly testing "passwd -d delete" \
  '$C -d root 2>/dev/null || echo denied' "denied\n" "" ""
