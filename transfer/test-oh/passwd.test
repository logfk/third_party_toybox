#!/bin/bash

# Test OHOS passwd adaptation:
# Conditionally frees encrypted password memory only when
# CFG_TOYBOX_FREE is set and -l flag is present

[ -f testing.sh ] && . testing.sh

# passwd --help (verify command exists)
ohosonly testing "passwd help" \
  '$C --help >/dev/null 2>&1 && echo ok' "ok\n" "" ""

# passwd -l (lock account, runs as root, write to /etc/passwd will fail on OHOS)
ohosonly testing "passwd -l lock" \
  '$C -l root 2>/dev/null; echo denied' "Locking 'root'\ndenied\n" "" ""

# passwd -u (unlock, root not locked due to -l failure above)
ohosonly testing "passwd -u unlock" \
  '$C -u root 2>/dev/null; echo denied' "denied\n" "" ""

# passwd -d (delete password, runs as root, write will fail on OHOS)
ohosonly testing "passwd -d delete" \
  '$C -d root 2>/dev/null; echo denied' "Deleting password for 'root'\ndenied\n" "" ""
