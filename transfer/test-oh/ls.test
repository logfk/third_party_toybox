#!/bin/bash

# Test OHOS ls adaptations:
# 1. File-first sorting when listing mixed file+dir arguments at top level.
# 2. Block size calculation (use raw st_blocks in total line).

[ -f testing.sh ] && . testing.sh

# File-first sorting: when multiple file+dir args are passed,
# files appear before directory headers.
mkdir -p adir bdir
touch afile bfile

ohosonly testcmd "dirs after files -1 (mixed args)" \
  "-1 adir afile bdir bfile" "afile\nbfile\n\nadir:\n\nbdir:\n" "" ""

ohosonly testcmd "dirs after files -s (mixed args)" \
  "-s adir afile bdir bfile" "0 afile\n0 bfile\n\nadir:\ntotal 0\n\nbdir:\ntotal 0\n" "" ""

rm -rf adir bdir afile bfile
