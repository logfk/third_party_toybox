#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# mountpoint checks if a directory is a mountpoint
ohosonly testcmd "help" \
  "--help 2>&1 | grep -qi 'mountpoint' && echo ok" "ok\n" "" ""

# / is always a mountpoint (suppress mountpoint's own output)
ohosonly testing "root is mountpoint" \
  "$C / >/dev/null && echo yes" "yes\n" "" ""

# -q quiet mode on / (should return 0)
ohosonly testing "-q /" \
  "$C -q / && echo yes" "yes\n" "" ""

# -d prints device number for /
ohosonly testing "-d root" \
  "$C -d / 2>&1 | grep -q ':' && echo ok" "ok\n" "" ""

# non-mountpoint directory (local dir, not /tmp)
ohosonly testing "tmpdir not mountpoint" \
  "mkdir -p _mp_testdir && $C _mp_testdir 2>&1 | grep -q 'not a' && echo ok; rm -rf _mp_testdir" "ok\n" "" ""
