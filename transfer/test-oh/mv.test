#!/bin/bash

# Test OHOS mv -v verbose output fix
# The fix prints "renamed 'src' -> 'dest'" when mv -v is used

[ -f testing.sh ] && . testing.sh

touch src1
ohosonly testcmd "mv -v prints renamed" \
  '-v src1 dest1 && echo ok' \
  "renamed 'src1' -> 'dest1'\nok\n" "" ""
rm -f src1 dest1

# Without -v should not print verbose message
touch src2
ohosonly testcmd "mv without -v silent" \
  'src2 dest2 && echo ok' \
  "ok\n" "" ""
rm -f src2 dest2

# mv -v across directories
mkdir -p subdir
touch src3
ohosonly testcmd "mv -v to directory" \
  '-v src3 subdir && echo ok' \
  "renamed 'src3' -> 'subdir/src3'\nok\n" "" ""
rm -rf src3 subdir
