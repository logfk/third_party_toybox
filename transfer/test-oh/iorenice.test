#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

ohosonly testcmd "help" "--help 2>&1 >/dev/null && echo ok" "ok\n" "" ""

# no args should fail (needs PID)
ohosonly testcmd "no args" "2>&1; echo \$?" "iorenice: Needs 1 argument (see \"iorenice --help\")\n1\n" "" ""

# query current process IO priority
ohosonly testcmd "query self" "$$ 2>/dev/null | grep -qi 'class' && echo ok || echo skip" "ok\n" "" ""
