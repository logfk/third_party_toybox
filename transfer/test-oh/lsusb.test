#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

ohosonly testcmd "help" "--help 2>&1 | grep -qi 'lsusb' && echo ok" "ok\n" "" ""

# no args lists USB devices (may be empty on some systems)
ohosonly testcmd "no args" "$C 2>&1; echo \$?" "0\n" "" ""
