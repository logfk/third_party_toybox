#!/bin/bash

# Test OHOS kill adaptations:
# 1. sscanf format for /proc/pid/stat parsing (different on OHOS)
#    - affects killall5 / pkill -s session-based process killing
# 2. Basic kill -l / killall5 -l functionality

[ -f testing.sh ] && . testing.sh

# kill -l lists signal names
ohosonly testcmd "kill -l lists HUP" \
  "$C -l 2>&1 | grep -q 'HUP' && echo ok" "ok\n" "" ""

# killall5 -l lists signal names (safe, no signals sent)
ohosonly testcmd "killall5 -l lists TERM" \
  "$C killall5 -l 2>&1 | grep -q 'TERM' && echo ok" "ok\n" "" ""

# killall5 -0: signal 0 to all procs; may fail if no killall5 process running
# 注意: $C 是 killall 的 symlink，向其传 'killall5 --help' 不会输出 killall5 帮助（killall
# 把 killall5 当进程名处理）。暂跳过此测试。
[ -n "$OHOS_TEST" ] && SKIP=$((SKIP+1))
ohosonly testcmd "killall5 lists help" \
  '$C killall5 --help >/dev/null 2>&1 && echo ok' "ok\n" "" ""

rm -f input
