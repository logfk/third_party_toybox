#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

ohosonly testing "mkdir" "$C one && [ -d one ] && echo yes" "yes\n" "" ""
rmdir one

touch existing
ohosonly testing "existing file"  	"$C existing 2> /dev/null || [ -f existing ] && echo yes" "yes\n" "" ""
rm existing

mkdir existing
ohosonly testing "existing dir"  	"$C existing 2> /dev/null || echo yes" "yes\n" "" ""
rmdir existing

ohosonly testing "one two"  	"$C one two && [ -d one ] && [ -d two ] && echo yes" "yes\n" "" ""
rmdir one two

ohosonly testing "missing/one"  	"$C missing/one 2> /dev/null || [ ! -d missing ] && echo yes" "yes\n" "" ""

ohosonly testing "-p"  	"$C -p one/two/three && [ -d one/two/three ] && echo yes" "yes\n" "" ""
rm -rf one

mkdir existing
ohosonly testing "-p existing" "$C -p existing && echo yes" "yes\n" "" ""
rmdir existing

umask 123
ohosonly testing "(default permissions)"  	"$C one && stat -c %a one" "654\n" "" ""
rmdir one

ohosonly testing "-m 124"  	"$C -m 124 one && stat -c %a one" "124\n" "" ""
rmdir one

umask 000
ohosonly testing "-p -m 653"  	"$C -p -m 653 one/two && stat -c %a one && stat -c %a one/two"  	"777\n653\n" "" ""
rm -rf one

ohosonly testing "-p one/two/ (trailing slash)"  	"$C -p one/two/ &&  [ -d one/two ] && echo yes" "yes\n" "" ""
rm -rf one

umask 022
ohosonly testing "-p -m 777 (022 umask)"  	"$C -p -m 777 one/two && stat -c %a one && stat -c %a one/two"  	"755\n777\n" "" ""
rm -rf one

umask 377
ohosonly testing "-p -m 777 (377 umask)"  	"$C -p -m 777 one/two && stat -c %a one && stat -c %a one/two"  	"700\n777\n" "" ""
umask 002
rm -rf one

ohosonly testing "-vp" "$C -vp walrus 2>&1"  	"mkdir: created directory 'walrus'\n" "" ""

ohosonly testing "-vp exists" "$C -vp walrus 2>&1"  	"" "" ""
rm -rf walrus

touch two
ohosonly testing "continue after fail"  	"$C -m 777 one two three 2>/dev/null || stat -c %a three"  	"777\n" "" ""
rm -rf one two three
