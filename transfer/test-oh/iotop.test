#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# iotop requires root (STAYROOT); skip gracefully if not root
[ "$(id -u)" -eq 0 ] || { SKIP=9999; }

# iotop -b -q quiet mode outputs process IO data to stdout
ohosonly testing "iotop -b -q -n1" \
  '$C -b -q -n1 2>/dev/null | wc -l | grep -q "[0-9]" && echo ok || echo skip' "ok\n" "" ""

# iotop -b batch mode, single iteration — verify first line is "Totals:"
ohosonly testing "iotop -b -n1 header" \
  '$C -b -n1 2>/dev/null | head -1 | grep -qi "totals" && echo ok || echo skip' "ok\n" "" ""

# iotop -b -n1 — verify PID column exists in output
ohosonly testing "iotop -b -n1 shows PID" \
  '$C -b -n1 2>/dev/null | head -2 | tail -1 | grep -qi "PID" && echo ok || echo skip' "ok\n" "" ""

# iotop --help
ohosonly testing "iotop --help" \
  '$C --help >/dev/null 2>&1 && echo ok || echo skip' "ok\n" "" ""

# iotop with invalid flag should fail
ohosonly testing "iotop invalid flag" \
  '$C --nonexistent >/dev/null 2>&1; echo $?' "1\n" "" ""
