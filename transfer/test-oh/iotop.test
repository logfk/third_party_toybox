#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# iotop requires root (STAYROOT); skip gracefully if not root
[ "$(id -u)" -eq 0 ] || { SKIP=9999; }

# iotop -b batch mode, single iteration — first line is "Totals: DREAD:..., ..."
ohosonly testing "iotop -b -n1 output" \
  '$C -b -n1 2>/dev/null | head -1 | grep -qi "totals\|DREAD\|DWRITE\|DIO\|pid\|comm" && echo ok || echo skip' "ok\n" "" ""

# iotop -b -d with custom delay
ohosonly testing "iotop -b -d 1 -n1" \
  '$C -b -d 1 -n1 2>/dev/null | head -1 | grep -qi "totals\|DREAD\|DWRITE\|DIO\|pid\|comm" && echo ok || echo skip' "ok\n" "" ""

# iotop -b -o only processes with active IO
ohosonly testing "iotop -b -o -n1" \
  '$C -b -o -n1 2>/dev/null | head -1 | grep -qi "totals\|DREAD\|DWRITE\|DIO\|pid\|comm" && echo ok || echo skip' "ok\n" "" ""

# iotop -b -q quiet mode (less output)
ohosonly testing "iotop -b -q -n1" \
  '$C -b -q -n1 2>/dev/null | wc -l | grep -q "[0-9]" && echo ok || echo skip' "ok\n" "" ""

# iotop --help
ohosonly testing "iotop --help" \
  '$C --help >/dev/null 2>&1 && echo ok || echo skip' "ok\n" "" ""

# iotop with invalid flag should fail
ohosonly testing "iotop invalid flag" \
  '$C --nonexistent >/dev/null 2>&1; echo $?' "1\n" "" ""
