#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

ohosonly testing "batch termination" "$C -b -n1 | tail -c 1" "\n" "" ""
ohosonly testing "fractional seconds" "$C -b -d 8.5 -n1 | tail -c 1" "\n" "" ""

# These are unit tests of xparsetime.
ohosonly testing "-d invalid input" "$C -b -d monkey -n1 2>&1 >/dev/null" "top: Not a number 'monkey'\n" "" ""
ohosonly testing "-d unknown suffix" "$C -b -d 1u -n1 2>&1 >/dev/null" "top: Unknown suffix 'u'\n" "" ""
ohosonly testing "-d suffix trailing junk" "$C -b -d 1monkey -n1 2>&1 >/dev/null" "top: Unknown suffix 'monkey'\n" "" ""
