#!/bin/bash

# Test OHOS dmesg adaptations:
# 1. Disable subsystem detection (OHOS kernel log has no ": " prefix)
# 2. Flipped color logic: ERROR/PANIC level >= 3 colored

[ -f testing.sh ] && . testing.sh

# dmesg basic output (non-zero bytes means we can read the log)
ohosonly testing "dmesg basic output" \
  '$C 2>/dev/null | head -5 | wc -c | grep -q "[1-9]" && echo ok' "ok\n" "" ""

# dmesg -T (human-readable timestamps, starts with [Day or date)
ohosonly testing "dmesg -T" \
  '$C -T 2>/dev/null | head -1 | grep -q "^\[" && echo ok' "ok\n" "" ""

# dmesg -c (clear ring buffer - requires root)
ohosonly testing "dmesg -c" \
  '$C -c 2>/dev/null >/dev/null && echo ok || echo skip' "ok\n" "" ""

# dmesg -r (raw)
ohosonly testing "dmesg -r" \
  '$C -r 2>/dev/null | head -1 | grep -q "<" && echo ok' "ok\n" "" ""
