#!/bin/bash

# Test OHOS bunzip2 adaptations:
# 1. -k (keep) mode: don't delete input, correct output naming
# 2. Without -k: delete input on success
# 3. -c (stdout) mode
# Uses embedded bzip2 data — no dependency on external bzip2.

[ -f testing.sh ] && . testing.sh

# Pre-compressed bzip2 blobs: printf '...\n' | bzip2 | base64 -d
_BZ1="QlpoOTFBWSZTWa7vtWwAAAlZgAAQQAAQADcg3BAgADFMAAEJ6Q0Mygo6sclhhVZK8V8XckU4UJCu77Vs"
_BZ2="QlpoOTFBWSZTWYzDsj8AAATRgAAQQAAmAAwAIAAiGTNQhgGZI6U8XckU4UJCMw7I/A=="
_BZ3="QlpoOTFBWSZTWQ6GvucAAANRgAAQQAAGAI4AIAAhoaPSEMCBJ6yWTxdyRThQkA6Gvuc="

# bunzip2 -k: decompress and keep .bz2 file
echo "$_BZ1" | base64 -d > k1.bz2

ohosonly testcmd "bunzip2 -k keeps input" \
  "-k k1.bz2 && [ -f k1.bz2 ] && echo ok" "ok\n" "" ""

rm -f k1
ohosonly testcmd "bunzip2 -k produces output" \
  "-k k1.bz2 && [ -f k1 ] && echo extracted" "extracted\n" "" ""

rm -f k1 k1.bz2

# bunzip2 without -k: should delete input on success
echo "$_BZ2" | base64 -d > k2.bz2

ohosonly testcmd "bunzip2 removes input" \
  "k2.bz2 && [ ! -f k2.bz2 ] && echo removed" "removed\n" "" ""

rm -f k2 k2.bz2

# bunzip2 to stdout (-c)
echo "$_BZ3" | base64 -d > k3.bz2

ohosonly testcmd "bunzip2 -c to stdout" \
  "-c k3.bz2" "stdout test\n" "" ""

rm -f k3 k3.bz2
