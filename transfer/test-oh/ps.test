#!/bin/bash

# Test OHOS ps adaptations:
# 1. %CPU sort with epsilon comparison (ps -eo pid,cmd,%cpu --sort=-%cpu)
# 2. Thread ordering by (pid, tid) tuple

[ -f testing.sh ] && . testing.sh

# ps -e (list all processes)
ohosonly testing "ps -e" \
  '$C -e 2>/dev/null | head -1 | grep -q "PID" && echo ok' "ok\n" "" ""

# ps -eo pid,cmd,%cpu --sort=-%cpu
ohosonly testing "ps sort by %CPU" \
  '$C -eo pid,cmd,%cpu --sort=-%cpu 2>/dev/null | head -3 | grep -q PID && echo ok' "ok\n" "" ""

# ps -T (thread display)
ohosonly testing "ps -T" \
  '$C -T 2>/dev/null | head -1 | grep -q "PID" && echo ok' "ok\n" "" ""

# === Flag tests for untested flags ===

# -a: all processes with terminal (not just own user)
ohosonly testing "ps -a shows processes" \
  '$C -a 2>/dev/null | grep -q . && echo ok' "ok\n" "" ""

# -u: user-oriented format
ohosonly testing "ps -u user format" \
  '$C -u 2>/dev/null | grep -q . && echo ok' "ok\n" "" ""

# -o: custom output format
ohosonly testing "ps -o custom format" \
  '$C -eo pid,comm 2>/dev/null | grep -q . && echo ok' "ok\n" "" ""

# -l: long format listing
ohosonly testing "ps -l long format" \
  '$C -l 2>/dev/null | grep -q . && echo ok' "ok\n" "" ""

# -A: show all processes
ohosonly testing "ps -A all processes" \
  '$C -A 2>/dev/null | head -1 | grep -q "PID" && echo ok' "ok\n" "" ""
