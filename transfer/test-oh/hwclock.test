#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

# --help always works, no hardware needed
ohosonly testing "help" "$C --help | grep -q 'hwclock' && echo yes" "yes\n" "" ""

# nonexistent rtc device should fail
ohosonly testing "bad rtc file" "$C -ruf /dev/nonexistent_rtc 2>&1; echo \$?" "hwclock: /dev/nonexistent_rtc: No such file or directory\n1\n" "" ""

# mutually exclusive flags: -r and -w together should error
ohosonly testing "rw conflict" "$C -rw 2>&1; echo \$?" "hwclock: No 'w' with 'r' (see \"hwclock --help\")\n1\n" "" ""

# mutually exclusive flags: -r and -s together should error
ohosonly testing "rs conflict" "$C -rs 2>&1; echo \$?" "hwclock: No 's' with 'r' (see \"hwclock --help\")\n1\n" "" ""

# mutually exclusive flags: -t and -w together should error
ohosonly testing "tw conflict" "$C -tw 2>&1; echo \$?" "hwclock: No 'w' with 't' (see \"hwclock --help\")\n1\n" "" ""

# -u and -l are NOT mutually exclusive (last one wins); verify they work
skipnot [ -e /dev/rtc0 ]
ohosonly testing "ul works" "$C -ul 2>&1 | grep -q '[0-9]' && echo yes" "yes\n" "" ""

# -r (show): needs /dev/rtc0; skip if absent
skipnot [ -e /dev/rtc0 ]
ohosonly testing "show" "$C -r | grep -q '[0-9]' && echo yes" "yes\n" "" ""

# -r with -u flag
skipnot [ -e /dev/rtc0 ]
ohosonly testing "show utc" "$C -ru | grep -q '[0-9]' && echo yes" "yes\n" "" ""

# -r with -l flag
skipnot [ -e /dev/rtc0 ]
ohosonly testing "show localtime" "$C -rl | grep -q '[0-9]' && echo yes" "yes\n" "" ""

# -f with custom rtc device file pointing to nonexistent path
ohosonly testing "custom rtc file" "$C -rf /dev/nonexistent_rtc 2>&1; echo \$?" "hwclock: /dev/nonexistent_rtc: No such file or directory\n1\n" "" ""

# -w (systohc) needs root and /dev/rtc0; skip if not available
skipnot [ "$(id -u)" -eq 0 ]
skipnot [ -e /dev/rtc0 ]
ohosonly testing "systohc" "$C -w && echo yes" "yes\n" "" ""

# -s (hctosys) needs root and /dev/rtc0; skip if not available
skipnot [ "$(id -u)" -eq 0 ]
skipnot [ -e /dev/rtc0 ]
ohosonly testing "hctosys" "$C -s && echo yes" "yes\n" "" ""

# -t (systz) needs root; skip if not root
skipnot [ "$(id -u)" -eq 0 ]
ohosonly testing "systz" "$C -t && echo yes" "yes\n" "" ""
