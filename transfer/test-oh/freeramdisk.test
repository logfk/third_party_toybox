#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

ohosonly testcmd "help" "--help 2>&1 | grep -qi 'freeramdisk' && echo ok" "ok\n" "" ""

# no args should fail (needs a ramdisk device)
ohosonly testcmd "no args" "$C 2>/dev/null; echo \$?" "1\n" "" ""
