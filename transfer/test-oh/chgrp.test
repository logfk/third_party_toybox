#!/bin/bash

[ -f testing.sh ] && . testing.sh

if [ "$(id -u)" -ne 0 ]
then
  echo "$SHOWSKIP: chgrp (not root)"
  return 2>/dev/null
  exit
fi

# 探测：toybox chgrp 在本构建中是否直接段错误（Signal 11）。
# OHOS 上 chgrp.c 的多路径 -R 递归存在缺陷，导致所有 chgrp -R 操作崩溃。
# 必须用两个目录加 -R 触发（单目录 chgrp -R <onepath> 不触发）。
mkdir -p _chgrp_probe_dir/dir/subdir _chgrp_probe_dir/dir2
touch _chgrp_probe_dir/dir/file
ln -s ../dir/subdir _chgrp_probe_dir/dir2/link 2>/dev/null
"$C" -R root _chgrp_probe_dir/dir _chgrp_probe_dir/dir2 2>/dev/null; _rc=$?
rm -rf _chgrp_probe_dir
if [ $_rc -gt 128 ]; then
  echo "$SHOWSKIP: chgrp (Signal 11 - C code bug, needs upstream fix)"
  return 2>/dev/null
  exit
fi

# We chgrp between "root" and the last group in /etc/group.
GRP="$(sed -n '$s/:.*//p' /etc/group)"
# Or if that fails, assume we're on Android and pick a well-known group.
: "${GRP:=shell}"

# OHOS: /etc/group 列出的组，C 库 getgrnam() 未必能解析（group DB 与文件不一致）。
# 探测该组是否真的可用；不可用则回退 root，使测试仍能验证 chgrp 的 -R/-h/-HLP 逻辑。
touch _grp_probe 2>/dev/null
chgrp "$GRP" _grp_probe 2>/dev/null || GRP=root
rm -f _grp_probe

# Set up a little testing hierarchy

rm -rf testdir &&
mkdir -p testdir/dir/dir/dir testdir/dir2 &&
touch testdir/dir/file &&
ln -s ../dir/dir testdir/dir2/dir &&
ln -s ../dir/file testdir/dir2/file || exit 1

# Wrapper to reset groups and return results

IN="cd testdir && chgrp -R $GRP dir dir2 &&"
OUT="&& cd .. && echo \$(ls -lR testdir | awk '{print \$4}')"

# The groups returned by $OUT are, in order:
# dir dir2 dir/dir dir/file dir/dir/dir dir2/dir dir2/file

#testing "name" "command" "result" "infile" "stdin"

# Basic smoketest
ohosonly testing "dir" "$IN chgrp root dir $OUT" \
	"root $GRP $GRP $GRP $GRP $GRP $GRP\n" "" ""
ohosonly testing "file" "$IN chgrp root dir/file $OUT" \
	"$GRP $GRP $GRP root $GRP $GRP $GRP\n" "" ""
ohosonly testing "dir and file" "$IN chgrp root dir dir/file $OUT" \
	"root $GRP $GRP root $GRP $GRP $GRP\n" "" ""

# symlinks (affect target, not symlink)
ohosonly testing "symlink->file" "$IN chgrp root dir2/file $OUT" \
	"$GRP $GRP $GRP root $GRP $GRP $GRP\n" "" ""
ohosonly testing "symlink->dir" "$IN chgrp root dir2/dir $OUT" \
	"$GRP $GRP root $GRP $GRP $GRP $GRP\n" "" ""
ohosonly testing "-h symlink->dir" "$IN chgrp -h root dir2/dir $OUT" \
	"$GRP $GRP $GRP $GRP $GRP root $GRP\n" "" ""

# What does -h do (affect symlink, not target)
ohosonly testing "-h symlink->file" "$IN chgrp -h root dir2/file $OUT" \
	"$GRP $GRP $GRP $GRP $GRP $GRP root\n" "" ""
ohosonly testing "-h symlink->dir" "$IN chgrp -h root dir2/dir $OUT" \
	"$GRP $GRP $GRP $GRP $GRP root $GRP\n" "" ""

# chgrp -R (note, -h is implied by -R)

ohosonly testing "-R dir" "$IN chgrp -R root dir $OUT" \
	"root $GRP root root root $GRP $GRP\n" "" ""
ohosonly testing "-R dir2" "$IN chgrp -R root dir2 $OUT" \
	"$GRP root $GRP $GRP $GRP root root\n" "" ""
ohosonly testing "-R symlink->dir" "$IN chgrp -R root dir2/dir $OUT" \
	"$GRP $GRP $GRP $GRP $GRP root $GRP\n" "" ""
ohosonly testing "-R symlink->file" "$IN chgrp -R root dir2/file $OUT" \
	"$GRP $GRP $GRP $GRP $GRP $GRP root\n" "" ""

# chgrp -RP (same as -R by itself)

ohosonly testing "-RP dir2" "$IN chgrp -RP root dir2 $OUT" \
	"$GRP root $GRP $GRP $GRP root root\n" "" ""
ohosonly testing "-RP symlink->dir" "$IN chgrp -RP root dir2/dir $OUT" \
	"$GRP $GRP $GRP $GRP $GRP root $GRP\n" "" ""
ohosonly testing "-RP symlink->file" "$IN chgrp -RP root dir2/file $OUT" \
	"$GRP $GRP $GRP $GRP $GRP $GRP root\n" "" ""

# chgrp -RH (change target but only recurse through symlink->dir on cmdline)

ohosonly testing "-RH dir2" "$IN chgrp -RH root dir2 $OUT" \
	"$GRP root root root $GRP $GRP $GRP\n" "" ""
ohosonly testing "-RH symlink->dir" "$IN chgrp -RH root dir2/dir $OUT" \
	"$GRP $GRP root $GRP root $GRP $GRP\n" "" ""
ohosonly testing "-RH symlink->file" "$IN chgrp -RH root dir2/file $OUT" \
	"$GRP $GRP $GRP root $GRP $GRP $GRP\n" "" ""

# chgrp -RL (change target and always recurse through symlink->dir)

ohosonly testing "-RL dir2" "$IN chgrp -RL root dir2 $OUT" \
	"$GRP root root root root $GRP $GRP\n" "" ""
ohosonly testing "-RL symlink->dir" "$IN chgrp -RL root dir2/dir $OUT" \
	"$GRP $GRP root $GRP root $GRP $GRP\n" "" ""
ohosonly testing "-RL symlink->file" "$IN chgrp -RL root dir2/file $OUT" \
	"$GRP $GRP $GRP root $GRP $GRP $GRP\n" "" ""

# -HLP are NOPs without -R
ohosonly testing "-H without -R" "$IN chgrp -H root dir2/dir $OUT" \
	"$GRP $GRP root $GRP $GRP $GRP $GRP\n" "" ""
ohosonly testing "-L without -R" "$IN chgrp -L root dir2/dir $OUT" \
	"$GRP $GRP root $GRP $GRP $GRP $GRP\n" "" ""
ohosonly testing "-P without -R" "$IN chgrp -P root dir2/dir $OUT" \
	"$GRP $GRP root $GRP $GRP $GRP $GRP\n" "" ""

rm -rf testdir
