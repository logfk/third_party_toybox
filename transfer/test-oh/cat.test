#!/bin/bash

[ -f testing.sh ] && . testing.sh

#testing "name" "command" "result" "infile" "stdin"

echo "one" > file1
echo "two" > file2
ohosonly testing "cat" "$C && echo yes" "oneyes\n" "" "one"
ohosonly testing "-" "$C - && echo yes" "oneyes\n" "" "one"
ohosonly testing "file1 file2" "$C file1 file2" "one\ntwo\n"  "" ""
ohosonly testing "- file"      "$C - file1"     "zero\none\n" "" "zero\n"
ohosonly testing "file -"      "$C file1 -"     "one\nzero\n" "" "zero\n"

ohosonly testing "file1 notfound file2"          "$C file1 notfound file2 2>stderr && echo ok ; $C stderr; rm stderr"          "one\ntwo\ncat: notfound: No such file or directory\n" "" ""

ohosonly testing "binary"          '$C /data/toybox-test/toybox > cattmp && cmp /data/toybox-test/toybox cattmp && echo yes; rm -f cattmp' "yes\n" "" ""

ohosonly testing "- file1"          "$C - file1 | tail -1"          "one\n" "" "hello\n"

skipnot [ -e /dev/full ]
ohosonly testing "> /dev/full"          "$C - > /dev/full 2>/dev/null || echo failed"          "failed\n" "" "zero\n"

rm file1 file2
